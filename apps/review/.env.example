# ── CAF Core API (the only data source) ──
# When Review runs embedded inside Core (`npm run dev` at repo root), Core sets CAF_CORE_URL automatically.
# Standalone Review dev: http://localhost:3847
# Legacy Vercel-only deploy: public Core URL (e.g. https://caf-core.fly.dev).
CAF_CORE_URL=http://localhost:3847
CAF_CORE_TOKEN=

# ── Workbench scope ──
# Leave PROJECT_SLUG empty to load every *active* project’s review queue (filter by project in the UI).
# Set PROJECT_SLUG=SNS (etc.) to lock the app to one tenant.
# Lock Review to the CAF tenant that owns your Meta integrations (after `npm run seed:meta-links`, default is `connecrts`):
# PROJECT_SLUG=connecrts
PROJECT_SLUG=
# Optional: force the multi-project queue even when PROJECT_SLUG is set (1 / true / yes).
# REVIEW_ALL_PROJECTS=0
# If CAF Core is older and has no GET /v1/review-queue-all/*, the app falls back to one tenant:
# set REVIEW_FALLBACK_PROJECT_SLUG=SNS (or deploy Core from this repo). Default fallback is SNS.
# REVIEW_FALLBACK_PROJECT_SLUG=

# ── Review app settings ──
# Embedded in Core: use Core's public URL (e.g. http://localhost:3847). Standalone Review dev: port 3000.
NEXT_PUBLIC_APP_URL=http://localhost:3847
# Protect decision writes from the UI (leave empty for local dev):
REVIEW_WRITE_TOKEN=

# ── Carousel live slide preview (server-side API calls the CAF renderer) ──
# Local renderer default in code is http://localhost:3333 — set this in production.
RENDERER_BASE_URL=http://localhost:3333
