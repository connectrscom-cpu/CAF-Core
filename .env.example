# =============================================================================
# CAF Core API (this repo) — copy to `.env` and fill values (never commit `.env`)
# =============================================================================

# --- Required: Postgres for CAF Core (dedicated DB or Supabase "Connection string" / URI mode)
# Example Supabase: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Default: Core applies pending SQL from ./migrations on startup (e.g. project_integrations). Set 0 to disable.
# CAF_RUN_MIGRATIONS_ON_START=0

# --- Fly.io secrets (split by app; do not copy renderer-only vars onto caf-core blindly)
# caf-core: DATABASE_URL, RENDERER_BASE_URL, VIDEO_ASSEMBLY_BASE_URL (e.g. https://caf-renderer.fly.dev),
#   OPENAI_API_KEY, optional SUPABASE_* (asset uploads), HEYGEN_API_KEY, CAF_CORE_API_TOKEN, CAF_CORE_REQUIRE_AUTH,
#   CAROUSEL_RENDERER_SLIDE_TIMEOUT_MS, CAF_SKIP_OUTPUT_SCHEMA_VALIDATION, etc.
# caf-renderer (media-gateway): CAF_TEMPLATE_API_URL=https://caf-core.fly.dev (Core GET /api/templates/* — public, no token),
#   SUPABASE_*, MUX_BURN_ENCODE_*,
#   VIDEO_ASSEMBLY_FETCH_TIMEOUT_MS, VIDEO_ASSEMBLY_FFMPEG_TIMEOUT_MS, VIDEO_ASSEMBLY_JOB_TIMEOUT_MS,
#   RENDERER_SHUTDOWN_SECRET. Deploy: fly deploy -c fly.caf-renderer.toml from repo root.

# Server
PORT=3847
HOST=0.0.0.0
NODE_ENV=development

# Optional: protect mutating/read APIs (except GET /health)
# When CAF_CORE_REQUIRE_AUTH=1, send header `x-caf-core-token: <same value>` or `Authorization: Bearer <same>`
CAF_CORE_API_TOKEN=
# When REQUIRE_AUTH=1 and API_TOKEN is set, /admin HTML embeds the token for in-browser cafFetch (trusted networks only).
CAF_CORE_REQUIRE_AUTH=0

# --- Publications (Review → Core placements; optional in-Core executor)
# none (default): external worker (e.g. n8n) posts to platforms and calls POST .../complete
# dry_run: Core completes placements immediately with a fake platform_post_id (infrastructure / CI tests)
# meta: Core calls Meta Graph (Facebook Page + Instagram) using project_integrations + Page access token
# CAF_PUBLISH_EXECUTOR=none
# META_GRAPH_API_VERSION=v21.0
# Optional Page token for meta executor (overrides DB); use Fly/Vercel secrets in prod, never commit.
# User access token with pages_show_list + pages_manage_posts is OK: Core calls GET /me/accounts and uses the Page token for your fb_page_id.
# Or paste a Page access_token directly. Not: deprecated user publish_actions-only tokens.
# CAF_META_PAGE_ACCESS_TOKEN=
# After migrate, seed Meta integrations (META_FB / META_IG + fb_page_id / ig_user_id). Examples:
#   npm run seed:meta-links
#   npm run seed:meta-links:sns
# All CAF projects can share the same Connectrs + Minha Terra Graph ids until you use separate Meta assets per brand.
#   npm run seed:meta-links -- --project SNS --name "Demo SNS" --fb-page-id YOUR_PAGE_ID --ig-user-id YOUR_IG_USER_ID
# Optional: SEED_PUBLISH_PROJECT_SLUG=connecrts SEED_PUBLISH_PROJECT_NAME="Connecrts Lda"
# Optional Graph ids (defaults = Connectrs Page + linked Minha Terra IG; same values for SNS/connecrts/etc.):
# SEED_META_FB_PAGE_ID=673711675834588
# SEED_META_IG_USER_ID=17841469638131849
# (`minhaterra.online` is the IG *account* in META_IG — not the CAF projects.slug.)

# Decision engine
DECISION_ENGINE_VERSION=v1
SCORE_WEIGHT_CONFIDENCE=0.35
SCORE_WEIGHT_PLATFORM_FIT=0.25
SCORE_WEIGHT_NOVELTY=0.2
SCORE_WEIGHT_PAST_PERF=0.2
DEFAULT_MIN_SCORE_TO_GENERATE=0.35
DEFAULT_MAX_VARIATIONS=1
# Optional global daily cap fallback when project constraints row is missing
# DEFAULT_MAX_DAILY_JOBS=100
# Aggregate plan caps when System limits leave max_*_jobs_per_run empty (carousel + video/reel totals per run).
# DEFAULT_MAX_CAROUSEL_JOBS_PER_RUN=10
# DEFAULT_MAX_VIDEO_JOBS_PER_RUN=4
# Per flow_type for non-carousel / non-video flows (stops N candidates × M flows exploding the plan).
# DEFAULT_OTHER_FLOW_PLAN_CAP=1

# --- CAF Core: asset uploads (carousel slides, HeyGen MP4, scenes) via Supabase Storage
# Same values as Review app / video-assembly when using one Supabase project.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ASSETS_BUCKET=assets
# Object keys are stored as {SUPABASE_ASSETS_BUCKET}/<kind>/… (e.g. assets/scenes/…) so the dashboard shows bucket → assets → scenes|videos|…
# Abort MP4 downloads (scene import, merged video) after this many ms; 0 = no limit (not recommended). Default 180000.
# STORAGE_HTTP_FETCH_TIMEOUT_MS=180000
# 1/true (default): on startup, seed empty top-level prefixes (scenes, videos, audios, …) with a tiny marker so they appear in Storage UI
# SUPABASE_ENSURE_ASSET_PREFIXES=1

# --- CAF Core: HeyGen video generation (v2 generate + v1 status)
HEYGEN_API_KEY=
# HEYGEN_API_BASE=https://api.heygen.com
# HeyGen v2 expects video_inputs[0].voice as TTS: { type: "text", voice_id, input_text } (Core builds this from your voice id + script).
# Set a real voice id from HeyGen (List Voices V2), or per flow in heygen_config (config_key: voice or voice_id).
# If unset, Core uses a documented sample multilingual voice (override for production).
# HEYGEN_DEFAULT_VOICE_ID=
# Avatar HeyGen flows only: if heygen_config has no prompt_avatar_id / pools, Core uses these (Fly secrets) so jobs do not fail empty.
# HEYGEN_DEFAULT_AVATAR_ID=your_heygen_avatar_uuid
# Or JSON array: [{"avatar_id":"...","voice_id":"..."}] (voice_id optional if HEYGEN_DEFAULT_VOICE_ID or DB voice row exists)
# HEYGEN_DEFAULT_AVATAR_POOL_JSON=
# Seconds for HeyGen voice.type "silence" when a job has only video_prompt (no spoken_script)—avoids TTS reading the whole visual prompt. Range 1–100.
# HEYGEN_VISUAL_ONLY_SILENCE_DURATION_SEC=15
# Video Agent full jobs: floor for duration_sec (bad/missing estimated_runtime_seconds → at least this; missing → VIDEO_TARGET_DURATION_MIN_SEC).
# Video Agent full-job duration floor (default 30s — short renders are usually bad LLM estimates)
# HEYGEN_AGENT_MIN_DURATION_SEC=30
# Scene HeyGen clip fallback: minimum duration_sec per scene (avoids 4s hints becoming 5s renders).
# HEYGEN_SCENE_AGENT_CLIP_MIN_SEC=12
# Target 5–7 scenes × ~4s clips (Sora-style stack ≈ 20–28s picture); Core trims excess scenes and sets duration hints.
# SCENE_ASSEMBLY_TARGET_SCENE_COUNT_MIN=6
# SCENE_ASSEMBLY_TARGET_SCENE_COUNT_MAX=7
# SCENE_ASSEMBLY_CLIP_DURATION_SEC=4
# Spoken script length vs scene timeline at 1× TTS (merge-from-storage expand + auto “short script” detection)
# SCENE_VO_WORDS_PER_MINUTE=145
# Headroom vs nominal wpm×seconds before hard trim (default 0.72 — TTS is often slower than textbook wpm)
# SCENE_VO_WORD_BUDGET_SAFETY=0.72
# Optional: ffmpeg atempo in mux so audio length matches video (alters speed). Default off — fit copy to clip length instead.
# SCENE_MUX_STRETCH_AUDIO_TO_VIDEO=false
# Scene assembly (default true): time-stretch TTS to stitched video length so burned subtitles match heard VO
# SCENE_ASSEMBLY_STRETCH_TTS_TO_VIDEO=1
# Main path: do not trim spoken_script before TTS (script flow is authoritative). Set true only for tight recovery mux.
# SCENE_ENFORCE_SPOKEN_SCRIPT_WORD_TRIM=false
# Prepend full VO + continuity to each Sora/HeyGen scene clip prompt (default on).
# SCENE_PREPEND_GLOBAL_CONTEXT_TO_CLIP_PROMPTS=true
# Min seconds per burned-in subtitle cue within a scene (merge sentences if the scene is too short)
# SCENE_SUBTITLE_MIN_CUE_SEC=1
# Per-scene clip renderer when URLs are missing: sora = OpenAI Videos API (Sora 2) + Supabase upload; heygen = HeyGen Video Agent no-avatar.
# SCENE_ASSEMBLY_CLIP_PROVIDER=sora
# OPENAI_API_BASE=https://api.openai.com/v1
# SORA_VIDEO_MODEL=sora-2
# SORA_VIDEO_SIZE=720x1280
# SORA_POLL_MAX_MS=900000
# Opt-in HeyGen per-scene clips when provider=heygen (default off; use sora or upstream URLs).
# SCENE_ASSEMBLY_HEYGEN_CLIP_FALLBACK=1
# Single-take / HeyGen script & prompt LLM fallbacks: aim spoken length ~30–60s.
# VIDEO_TARGET_DURATION_MIN_SEC=30
# VIDEO_TARGET_DURATION_MAX_SEC=60

# --- CAF Core: OpenAI TTS (scene post-process / voiceover)
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=nova

# =============================================================================
# Legacy CAF stack (Review app, renderer, video-assembly, n8n) — fill what you use
# =============================================================================

# --- Supabase (browser + server for Review app / video upload)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ASSETS_BUCKET=assets

# --- Review Console (Next.js)
REVIEW_WRITE_TOKEN=
NEXT_PUBLIC_REVIEW_WRITE_TOKEN=
DECISION_WEBHOOK_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000
CACHE_TTL_SECONDS=
REVIEW_QUEUE_STORAGE_THUMB_MAX=

# --- Google Sheets (Review Queue + legacy CAF workbooks)
GOOGLE_REVIEW_QUEUE_SPREADSHEET_ID=
GOOGLE_REVIEW_QUEUE_SPREADSHEET_IDS_EXTRA=
GOOGLE_REVIEW_QUEUE_SHEET_NAME=Review Queue
REVIEW_QUEUE_NO_CUISINA_SHEET=
# Service account JSON as a single-line string (production) OR use file path locally:
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
# OAuth path (alternative to service account):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Operational inventory (document in vault — not read by CAF Core server)
# VALIDATION spreadsheet, CREATION Runtime, PROCESSING insights, Flow Engine IDs:
# CAF_SHEET_VALIDATION_ID=
# CAF_SHEET_CREATION_RUNTIME_ID=
# CAF_SHEET_PROCESSING_INSIGHTS_ID=
# CAF_SHEET_FLOW_ENGINE_ID=

# --- Fly / media services (CAF Core job pipeline calls these)
# Carousel: POST {RENDERER_BASE_URL}/render-binary — no trailing slash.
# Must be the Puppeteer renderer (services/renderer) or media-gateway — NOT CAF Core. If RENDERER_BASE_URL
# points at Core, you get Fastify 404: "Route POST:/render-binary not found".
# Video assembly (non-HeyGen path): POST {VIDEO_ASSEMBLY_BASE_URL}/full-pipeline
# Scene assembly (multi-scene): concat/mux in Core — each scene in scene_bundle.scenes[] must have a public clip URL
# (rendered_scene_url, video_url, …) from upstream (e.g. n8n Sora/OpenAI video + stitch).
#
# Production: Fly app `caf-renderer` (fly.caf-renderer.toml) is the **media-gateway** — one host for renderer + video-assembly.
#   RENDERER_BASE_URL=https://caf-renderer.fly.dev
#   VIDEO_ASSEMBLY_BASE_URL=https://caf-renderer.fly.dev
# Gateway proxies POST /concat-videos, /stitch, /mux, /full-pipeline and GET /status/:id to the child video-assembly process.
# Do NOT point VIDEO_ASSEMBLY at a **standalone** renderer image (services/renderer/Dockerfile only) — it has no /concat-videos or /status.
#
# If you split apps: RENDERER_BASE_URL → renderer host; VIDEO_ASSEMBLY_BASE_URL → video-assembly:3334 or a gateway that proxies both.
RENDERER_BASE_URL=
# Per-slide timeout for carousel PNG requests from CAF Core (default 120000).
# CAROUSEL_RENDERER_SLIDE_TIMEOUT_MS=120000
# Extra POST /render-binary attempts after transient 5xx (Puppeteer Target closed, etc.); total tries = 1 + this.
# CAROUSEL_RENDERER_SLIDE_RETRY_ATTEMPTS=2
VIDEO_ASSEMBLY_BASE_URL=
# Core: carousel .hbs are read from CAROUSEL_TEMPLATES_DIR (default: services/renderer/templates locally; /app/carousel-templates in Docker).
# CAROUSEL_TEMPLATES_DIR=
# Renderer Fly secret: point at Core so disk misses still resolve (GET /api/templates/* is public when auth is on).
# CAF_TEMPLATE_API_URL=https://caf-core.fly.dev

# --- Renderer (Fly)
RENDERERS_BEFORE_RESET=12
RENDERER_SHUTDOWN_SECRET=

# --- Video assembly / mux (Fly)
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_WHISPER_TIMEOUT_MS=
VIDEO_ASSEMBLY_FETCH_TIMEOUT_MS=
VIDEO_ASSEMBLY_FFMPEG_TIMEOUT_MS=
VIDEO_ASSEMBLY_JOB_TIMEOUT_MS=
FFMPEG_PATH=
FFPROBE_PATH=
FFPROBE_TIMEOUT_MS=
TMP_DIR=
# Scene pipeline: optional full ffmpeg -vf value (overrides MUX_BURN_SUBTITLE_FORCE_STYLE), e.g. subtitles=captions.srt:charenc=UTF-8
MUX_SUBTITLE_VF=
MUX_BURN_SUBTITLE_FORCE_STYLE=
MUX_BURN_ENCODE_PRESET=
MUX_BURN_ENCODE_CRF=
MUX_CHUNK_SCRIPT_MAX_CHARS=
MUX_MIN_CAPTION_SEC=
MUX_CAPTION_WEIGHT_EXPONENT=
MUX_CAPTION_TIMING_MODE=
MUX_USE_SCENE_DURATION_FOR_SRT=
MUX_SUBTITLE_DURATION_SCALE=
MUX_SUBTITLE_ALIGN=
MUX_WHISPER_CAPTION_SOURCE=
MUX_SYNC_SUPABASE_TASK=
SUPABASE_UPLOAD_MAX_ATTEMPTS=
SUPABASE_UPLOAD_RETRY_MS=

# --- Media gateway (Fly)
RENDERER_PORT=3333
VIDEO_ASSEMBLY_PORT=3334

# --- GitHub Actions → Fly deploy
FLY_API_TOKEN=
FLY_RENDERER_APP=

# --- n8n (credentials live in n8n UI; record base URL for ops)
N8N_BASE_URL=
# Apify, OpenAI, HeyGen, HTTP bearer to Fly — stored as n8n Credentials:
APIFY_API_TOKEN=
HEYGEN_API_KEY=

# --- OpenAI (LLM / TTS outside video-assembly)
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# =============================================================================
# Adapters (sync legacy data into CAF Core Postgres)
# =============================================================================
# Sheets adapter  → npm run sync:sheets
GOOGLE_RUNTIME_SHEET_NAME=Runtime
PROJECT_SLUG=SNS

# Supabase adapter → npm run sync:supabase
SUPABASE_URL=
SYNC_SINCE_HOURS=72

# =============================================================================
# Review App (apps/review) — CAF Core integration
# =============================================================================
CAF_CORE_URL=http://localhost:3847
CAF_CORE_TOKEN=
# Empty = all active projects in the workbench; set SNS (etc.) for a single tenant (see apps/review/.env.example).
# PROJECT_SLUG=

# =============================================================================
# Optional: integration hooks for future adapters
# =============================================================================
# WEBHOOK_N8N_DECISION_SYNC_URL=
# WEBHOOK_N8N_DECISION_SYNC_SECRET=

# =============================================================================
# Master checklist (what YOU must fill — no secrets in git)
# =============================================================================
# See: docs/USER_INPUT_AND_SECRETS.md
# Local DB example (docker compose): postgresql://caf:caf@localhost:5433/caf_core

# Demo SNS (slug SNS): carousel + 4 video allowed_flow_types (creates project if missing)
#   npm run seed:canonical-flows
#   Replace entire Allowed Flow Types list with canonical 5 only: CAF_RESET_ALLOWED_FLOWS=1 npm run seed:canonical-flows
#   alias: npm run seed:demo-sns
# Full demo (constraints + prompt_versions + canonical flows): SEED_PROJECT_SLUG=SNS SEED_PROJECT_NAME="Demo SNS" npm run seed:demo
# Flow Engine seed: FLOW_ENGINE_XLSX=path/to/Flow_Engine.xlsx npm run seed:flow-engine

# LLM generation model (used by pipeline)
OPENAI_MODEL=gpt-4o
# Editorial analysis on an interval inside the API (pending rules + engineering insight + OpenAI on notes when key set)
# EDITORIAL_ANALYSIS_CRON_ENABLED=1
# EDITORIAL_ANALYSIS_CRON_INTERVAL_MS=86400000
# EDITORIAL_ANALYSIS_CRON_INITIAL_DELAY_MS=120000
# EDITORIAL_ANALYSIS_CRON_WINDOW_DAYS=30
# EDITORIAL_ANALYSIS_CRON_PROJECT_SLUGS=SNS
# One-shot CLI (Docker/Fly): npm run editorial-analysis -- SNS
# Post-approval LLM review (vision + text on APPROVED jobs only): OPENAI_APPROVAL_REVIEW_MODEL=gpt-4o
# LLM_APPROVAL_REVIEW_MAX_IMAGES=6
# LLM_APPROVAL_REVIEW_MAX_TEXT_CHARS=28000
# Max completion tokens sent to OpenAI (caps prompt template values; gpt-4o max is 16384)
# OPENAI_MAX_COMPLETION_TOKENS=16384
# Shrink signal_pack JSON in prompts so 128k-context models do not 400 (carousel + video flows)
# LLM_SIGNAL_PACK_JSON_MAX_CHARS=88000
# LLM_SIGNAL_PACK_MAX_CANDIDATE_ROWS=55
# LLM_SIGNAL_PACK_MAX_STRING_FIELD_CHARS=14000
# When unset, LLM output is not validated against output_schemas. Set to 0/false to enforce schemas.
# CAF_SKIP_OUTPUT_SCHEMA_VALIDATION=0
# When unset/true (default), QC never sets recommended_route AUTO_PUBLISH — passing jobs get HUMAN_REVIEW.
# CAF_REQUIRE_HUMAN_REVIEW_AFTER_QC=0
# Scene-assembly candidate router (LLM seeds per run; 0 = off)
# SCENE_ASSEMBLY_ROUTER_MAX_SEEDS=5
