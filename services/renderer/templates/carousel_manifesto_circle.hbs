<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <title>Carousel — Manifesto Circle</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@800;900&family=Outfit:wght@500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --safe: 90px;
      --ink: #0f0f14;
      --paper-pink: #ffd6e7;
      --paper-lilac: #e7def7;
      --paper-mint: #d4f4dd;
      --paper-lemon: #fff3b0;
      --paper-peach: #ffd8c2;
      --circle: #fff3f7;
      --accent: #ff2a55;
      --violet: #6a3dff;
      --mint: #1cb07a;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Outfit', sans-serif; background: #0f0f14; color: var(--ink); }
    .slide { width: 1080px; height: 1350px; overflow: hidden; flex-shrink: 0; position: relative; }
    .slide-inner {
      width: 100%; height: 100%;
      position: relative;
      padding: var(--safe);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      background: var(--paper-pink);
    }
    .slide:nth-of-type(5n+2) .slide-inner { background: var(--paper-lilac); }
    .slide:nth-of-type(5n+3) .slide-inner { background: var(--paper-mint); }
    .slide:nth-of-type(5n+4) .slide-inner { background: var(--paper-lemon); }
    .slide:nth-of-type(5n+5) .slide-inner { background: var(--paper-peach); }

    .circle {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 880px; height: 880px;
      border-radius: 50%;
      background: var(--circle);
      z-index: 1;
    }

    .stage { position: relative; z-index: 3; max-width: 760px; }
    .headline {
      font-family: 'Inter', sans-serif;
      font-weight: 900;
      font-size: clamp(140px, 14vw, 180px);
      line-height: 0.98;
      letter-spacing: -0.035em;
      color: var(--ink);
    }
    .headline .dot { color: var(--accent); }
    .body-copy {
      font-family: 'Outfit', sans-serif;
      font-weight: 500;
      font-size: clamp(46px, 4.6vw, 56px);
      line-height: 1.3;
      color: var(--ink);
      margin-top: 28px;
      max-width: 720px;
    }
    .tag {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 32px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink);
      opacity: 0.7;
      margin-top: 40px;
    }
    .cta-handle {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 44px;
      color: var(--accent);
      margin-top: 24px;
    }

    .deco { position: absolute; z-index: 2; }
    .deco.tl { top: 60px; left: 70px; width: 220px; height: 220px; }
    .deco.tr { top: 90px; right: 80px; width: 180px; height: 180px; }
    .deco.bl { bottom: 80px; left: 90px; width: 200px; height: 200px; }
    .deco.br { bottom: 70px; right: 80px; width: 210px; height: 210px; }
  </style>
</head>
<body>
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <symbol id="megaphone" viewBox="0 0 220 220">
        <path d="M40 110 L40 160 L70 160 L80 175 L95 170 L90 155 L160 180 L175 50 L95 80 L80 80 Z" fill="#2f7b5a" stroke="#0f0f14" stroke-width="6" stroke-linejoin="round"/>
        <rect x="25" y="115" width="18" height="36" fill="#8fd2ad" stroke="#0f0f14" stroke-width="6"/>
        <path d="M180 80 L210 60" stroke="#ffc63d" stroke-width="10" stroke-linecap="round"/>
        <path d="M185 110 L220 110" stroke="#ff6b2c" stroke-width="10" stroke-linecap="round"/>
        <path d="M180 140 L210 160" stroke="#ffc63d" stroke-width="10" stroke-linecap="round"/>
      </symbol>
      <symbol id="lips" viewBox="0 0 220 220">
        <circle cx="110" cy="110" r="96" fill="#ffffff" stroke="#0f0f14" stroke-width="4"/>
        <path d="M40 120 Q70 80 110 110 Q150 80 180 120 Q150 170 110 160 Q70 170 40 120 Z" fill="#ff2a55" stroke="#0f0f14" stroke-width="5"/>
        <path d="M55 125 Q110 140 165 125" stroke="#ffffff" stroke-width="10" fill="none" stroke-linecap="round"/>
        <path d="M95 120 Q110 112 125 120" stroke="#ffffff" stroke-width="6" fill="none" stroke-linecap="round"/>
      </symbol>
      <symbol id="flag" viewBox="0 0 220 220">
        <rect x="55" y="20" width="10" height="200" fill="#3e3bff"/>
        <path d="M65 20 Q150 30 200 40 Q160 80 200 120 Q150 115 65 130 Z" fill="#3e3bff" stroke="#0f0f14" stroke-width="4"/>
        <circle cx="130" cy="80" r="26" fill="none" stroke="#ffffff" stroke-width="9"/>
        <line x1="130" y1="106" x2="130" y2="130" stroke="#ffffff" stroke-width="9"/>
        <line x1="115" y1="120" x2="145" y2="120" stroke="#ffffff" stroke-width="9"/>
      </symbol>
      <symbol id="bolt" viewBox="0 0 220 220">
        <polygon points="100,20 60,120 110,120 90,200 170,90 120,90 140,20" fill="#ffc63d" stroke="#0f0f14" stroke-width="6"/>
      </symbol>
    </defs>
  </svg>

  <div class="slide cover">
    <div class="slide-inner">
      <span class="circle"></span>
      <svg class="deco tl"><use href="#megaphone"/></svg>
      <svg class="deco tr"><use href="#lips"/></svg>
      <svg class="deco br"><use href="#flag"/></svg>
      <svg class="deco bl"><use href="#bolt"/></svg>
      <div class="stage">
        <div class="headline">{{#if cover}}{{cover}}{{else}}{{cover_slide.headline}}{{/if}}<span class="dot">.</span></div>
        {{#if cover_slide.body}}<p class="body-copy">{{cover_slide.body}}</p>{{/if}}
      </div>
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <span class="circle"></span>
      <svg class="deco tl"><use href="#bolt"/></svg>
      <svg class="deco tr"><use href="#megaphone"/></svg>
      <svg class="deco br"><use href="#flag"/></svg>
      <div class="stage">
        <div class="headline">{{headline}}<span class="dot">.</span></div>
        {{#if body}}<p class="body-copy">{{body}}</p>{{/if}}
      </div>
    </div>
  </div>
  {{/each}}

  <div class="slide">
    <div class="slide-inner">
      <span class="circle"></span>
      <svg class="deco tl"><use href="#megaphone"/></svg>
      <svg class="deco tr"><use href="#lips"/></svg>
      <svg class="deco bl"><use href="#bolt"/></svg>
      <svg class="deco br"><use href="#flag"/></svg>
      <div class="stage">
        <div class="headline">{{#if cta_text}}{{cta_text}}{{else}}{{cta_slide.body}}{{/if}}<span class="dot">.</span></div>
        {{#if cta_handle}}<div class="cta-handle">{{cta_handle}}</div>{{else}}{{#if cta_slide.handle}}<div class="cta-handle">{{cta_slide.handle}}</div>{{/if}}{{/if}}
      </div>
    </div>
  </div>
</body>
</html>
