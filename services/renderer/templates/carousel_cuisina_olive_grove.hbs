<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <title>Cuisina — Olive Grove</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,700;1,400&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --cream: #fefae0;
      --olive: #606c38;
      --olive-dark: #283618;
      --gold: #dda15e;
      --muted-ink: #3d442a;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Source Sans 3', sans-serif; background: #1a1c14; color: var(--olive-dark); }
    .slide { width: 1080px; height: 1350px; overflow: hidden; flex-shrink: 0; }
    .slide-inner {
      width: 100%; height: 100%; position: relative;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 76px 68px;
      text-align: center;
      background: linear-gradient(168deg, #4a5d2e 0%, var(--olive) 38%, #3a4a28 72%, #252b18 100%);
    }
    .olive-ring {
      position: absolute; border: 3px solid rgba(221,161,94,0.35);
      border-radius: 50%; pointer-events: none;
    }
    .olive-ring.r1 { width: 520px; height: 520px; top: 8%; left: 50%; transform: translateX(-50%); opacity: 0.5; }
    .olive-ring.r2 { width: 720px; height: 720px; bottom: -8%; right: -12%; opacity: 0.25; }
    .card {
      position: relative; z-index: 2; max-width: 880px;
      padding: 46px 48px 50px;
      border-radius: 8px;
      background: var(--cream);
      box-shadow: 0 28px 70px rgba(0,0,0,0.42);
      border: 2px solid rgba(96,108,56,0.2);
    }
    .title-text {
      font-family: 'Libre Baskerville', serif;
      font-size: clamp(54px, 5.8vw, 76px);
      font-weight: 700;
      color: var(--olive-dark);
      line-height: 1.18;
    }
    .subtitle-text {
      font-family: 'Source Sans 3', sans-serif;
      font-size: clamp(30px, 3vw, 38px);
      color: var(--olive);
      margin-top: 20px;
      font-weight: 600;
    }
    .body-title {
      font-family: 'Libre Baskerville', serif;
      font-size: clamp(44px, 4.6vw, 58px);
      color: var(--olive-dark);
      margin-bottom: 24px;
      line-height: 1.15;
    }
    .body-text {
      font-family: 'Source Sans 3', sans-serif;
      font-size: clamp(32px, 3.2vw, 40px);
      line-height: 1.45;
      color: var(--muted-ink);
      max-width: 760px;
    }
    .cta-text {
      font-family: 'Libre Baskerville', serif;
      font-size: clamp(52px, 5.4vw, 68px);
      font-weight: 700;
      color: var(--olive-dark);
    }
    .cta-handle {
      font-family: 'Source Sans 3', sans-serif;
      font-size: clamp(32px, 3.3vw, 40px);
      color: var(--gold);
      margin-top: 14px;
      font-weight: 600;
    }
    .ribbon {
      font-size: 12px; letter-spacing: 0.35em; text-transform: uppercase;
      color: var(--olive); margin-bottom: 16px; font-weight: 600;
    }
  </style>
</head>
<body>

  <div class="slide">
    <div class="slide-inner">
      <span class="olive-ring r1"></span><span class="olive-ring r2"></span>
      <div class="card">
        <div class="ribbon">Mediterranean table</div>
        <span class="title-text">{{#if cover}}{{cover}}{{else}}{{#if cover_slide}}{{cover_slide.headline}}{{else}}{{intro_title}}{{/if}}{{/if}}</span>
        {{#if cover_subtitle}}<span class="subtitle-text">{{cover_subtitle}}</span>{{else}}{{#if cover_slide.body}}<span class="subtitle-text">{{cover_slide.body}}</span>{{/if}}{{/if}}
      </div>
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <span class="olive-ring r1"></span>
      <div class="card">
        <span class="body-title">{{headline}}</span>
        <p class="body-text">{{body}}</p>
      </div>
    </div>
  </div>
  {{/each}}

  <div class="slide">
    <div class="slide-inner">
      <span class="olive-ring r2"></span>
      <div class="card">
        <div class="ribbon">Taste more</div>
        <span class="cta-text">{{#if cta_text}}{{cta_text}}{{else}}{{#if cta_slide}}{{cta_slide.body}}{{/if}}{{/if}}</span>
        {{#if cta_handle}}<span class="cta-handle">{{cta_handle}}</span>{{else}}{{#if cta_slide.handle}}<span class="cta-handle">{{cta_slide.handle}}</span>{{/if}}{{/if}}
      </div>
    </div>
  </div>

</body>
</html>
