<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <title>Cuisina — Olive Grove</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,700;1,400&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --cream: #fefae0;
      --olive: #606c38;
      --olive-dark: #283618;
      --gold: #dda15e;
      --muted-ink: #3d442a;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Source Sans 3', sans-serif; background: #1a1c14; color: var(--olive-dark); }
    .slide { width: 1080px; height: 1350px; overflow: hidden; flex-shrink: 0; }
    .slide-inner {
      width: 100%; height: 100%; position: relative;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 76px 68px;
      text-align: center;
      background: linear-gradient(168deg, #4a5d2e 0%, var(--olive) 38%, #3a4a28 72%, #252b18 100%);
    }
    .olive-ring {
      position: absolute; border: 3px solid rgba(221,161,94,0.35);
      border-radius: 50%; pointer-events: none;
    }
    .olive-ring.r1 { width: 520px; height: 520px; top: 8%; left: 50%; transform: translateX(-50%); opacity: 0.5; }
    .olive-ring.r2 { width: 720px; height: 720px; bottom: -8%; right: -12%; opacity: 0.25; }
    .card {
      position: relative; z-index: 2; max-width: 880px;
      padding: 46px 48px 50px;
      border-radius: 8px;
      background: var(--cream);
      box-shadow: 0 28px 70px rgba(0,0,0,0.42);
      border: 2px solid rgba(96,108,56,0.2);
      overflow: hidden;
    }
    .cover-stack {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 28px;
      max-width: 100%;
    }
    .title-text {
      font-family: 'Libre Baskerville', serif;
      font-size: clamp(54px, 5.8vw, 76px);
      font-weight: 700;
      color: var(--olive-dark);
      line-height: 1.18;
      margin: 0;
      max-width: 100%;
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    /* Body / deck copy: clearly subordinate to the display title (not a second headline). */
    .cover-body {
      font-family: 'Source Sans 3', sans-serif;
      font-size: clamp(26px, 2.65vw, 34px);
      font-weight: 400;
      color: var(--muted-ink);
      margin: 0;
      line-height: 1.5;
      max-width: 720px;
      overflow-wrap: anywhere;
      word-break: break-word;
      white-space: pre-wrap;
    }
    .cover-subtitle {
      font-weight: 600;
      color: var(--olive);
      font-size: clamp(28px, 2.85vw, 36px);
    }
    .body-title {
      font-family: 'Libre Baskerville', serif;
      font-size: clamp(44px, 4.6vw, 58px);
      color: var(--olive-dark);
      margin: 0 0 28px 0;
      line-height: 1.15;
      max-width: 100%;
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    .body-text {
      font-family: 'Source Sans 3', sans-serif;
      font-size: clamp(30px, 3vw, 38px);
      line-height: 1.52;
      color: var(--muted-ink);
      max-width: 760px;
      margin: 0;
      overflow-wrap: anywhere;
      word-break: break-word;
      white-space: pre-wrap;
    }
    .cta-stack {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 18px;
      max-width: 100%;
    }
    .cta-text {
      font-family: 'Libre Baskerville', serif;
      font-size: clamp(56px, 5.8vw, 74px);
      font-weight: 700;
      color: var(--olive-dark);
      margin: 0;
      line-height: 1.14;
      max-width: 100%;
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    .cta-handle {
      font-family: 'Source Sans 3', sans-serif;
      font-size: clamp(34px, 3.5vw, 44px);
      color: var(--gold);
      margin: 0;
      font-weight: 600;
      overflow-wrap: anywhere;
    }
    .ribbon {
      font-size: 12px; letter-spacing: 0.35em; text-transform: uppercase;
      color: var(--olive); margin-bottom: 16px; font-weight: 600;
    }
  </style>
</head>
<body>

  <div class="slide">
    <div class="slide-inner">
      <span class="olive-ring r1"></span><span class="olive-ring r2"></span>
      <div class="card">
        <div class="ribbon">Mediterranean table</div>
        <div class="cover-stack">
          <h1 class="title-text">{{#if cover}}{{cover}}{{else}}{{#if cover_slide}}{{cover_slide.headline}}{{else}}{{intro_title}}{{/if}}{{/if}}</h1>
          {{#if cover_subtitle}}
          <p class="cover-body cover-subtitle">{{cover_subtitle}}</p>
          {{else}}
          {{#if cover_slide.body}}<p class="cover-body">{{cover_slide.body}}</p>{{/if}}
          {{/if}}
        </div>
      </div>
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <span class="olive-ring r1"></span>
      <div class="card">
        <h2 class="body-title">{{headline}}</h2>
        <p class="body-text">{{body}}</p>
      </div>
    </div>
  </div>
  {{/each}}

  <div class="slide">
    <div class="slide-inner">
      <span class="olive-ring r2"></span>
      <div class="card">
        <div class="ribbon">Taste more</div>
        <div class="cta-stack">
          <p class="cta-text">{{#if cta_text}}{{cta_text}}{{else}}{{#if cta_slide}}{{cta_slide.body}}{{/if}}{{/if}}</p>
          {{#if cta_handle}}<p class="cta-handle">{{cta_handle}}</p>{{else}}{{#if cta_slide.handle}}<p class="cta-handle">{{cta_slide.handle}}</p>{{/if}}{{/if}}
        </div>
      </div>
    </div>
  </div>

</body>
</html>
