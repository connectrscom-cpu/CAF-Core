<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <title>Cuisina — Herb Garden</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,600;1,9..144,500&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --mint: #d8f3dc;
      --forest: #1b4332;
      --sage: #52b788;
      --leaf: #40916c;
      --ink: #0d1f17;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: #0a1610; color: var(--ink); }
    .slide { width: 1080px; height: 1350px; overflow: hidden; flex-shrink: 0; }
    .slide-inner {
      width: 100%; height: 100%; position: relative;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 72px 64px;
      text-align: center;
      background: radial-gradient(ellipse 120% 80% at 50% 0%, #2d6a4f 0%, var(--forest) 45%, #08140e 100%);
    }
    .herb {
      position: absolute; border-radius: 50% 50% 40% 60%;
      opacity: 0.22; pointer-events: none;
    }
    .herb.a { width: 280px; height: 180px; background: var(--sage); top: 6%; left: -4%; transform: rotate(-18deg); }
    .herb.b { width: 220px; height: 140px; background: var(--leaf); bottom: 10%; right: -3%; transform: rotate(22deg); }
    .panel {
      position: relative; z-index: 2; max-width: 900px;
      padding: 48px 52px 52px;
      border-radius: 28px;
      background: linear-gradient(165deg, rgba(216,243,220,0.96) 0%, rgba(180,224,195,0.93) 100%);
      box-shadow: 0 24px 64px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.5);
      border: 1px solid rgba(27,67,50,0.12);
    }
    .title-text {
      font-family: 'Fraunces', serif;
      font-size: clamp(58px, 6.2vw, 80px);
      font-weight: 600;
      color: var(--forest);
      line-height: 1.14;
      letter-spacing: -0.02em;
    }
    .subtitle-text {
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(32px, 3.2vw, 40px);
      color: var(--leaf);
      margin-top: 18px;
      font-weight: 500;
      letter-spacing: 0.02em;
    }
    .body-title {
      font-family: 'Fraunces', serif;
      font-size: clamp(48px, 5vw, 62px);
      color: var(--forest);
      margin-bottom: 22px;
      line-height: 1.12;
    }
    .body-text {
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(34px, 3.4vw, 42px);
      line-height: 1.42;
      color: #1a3d2e;
      max-width: 780px;
      text-align: center;
    }
    .cta-text {
      font-family: 'Fraunces', serif;
      font-size: clamp(56px, 6vw, 74px);
      font-weight: 600;
      color: var(--forest);
    }
    .cta-handle {
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(34px, 3.5vw, 42px);
      color: var(--leaf);
      margin-top: 16px;
      font-weight: 500;
    }
    .badge {
      display: inline-block; margin-bottom: 18px;
      font-size: 13px; letter-spacing: 0.28em; text-transform: uppercase;
      color: rgba(27,67,50,0.65); font-weight: 600;
    }
  </style>
</head>
<body>

  <div class="slide">
    <div class="slide-inner">
      <span class="herb a"></span><span class="herb b"></span>
      <div class="panel">
        <span class="badge">Cuisina · fresh picks</span>
        <span class="title-text">{{#if cover}}{{cover}}{{else}}{{#if cover_slide}}{{cover_slide.headline}}{{else}}{{intro_title}}{{/if}}{{/if}}</span>
        {{#if cover_subtitle}}<span class="subtitle-text">{{cover_subtitle}}</span>{{else}}{{#if cover_slide.body}}<span class="subtitle-text">{{cover_slide.body}}</span>{{/if}}{{/if}}
      </div>
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <span class="herb a"></span>
      <div class="panel">
        <span class="body-title">{{headline}}</span>
        <p class="body-text">{{body}}</p>
      </div>
    </div>
  </div>
  {{/each}}

  <div class="slide">
    <div class="slide-inner">
      <span class="herb b"></span>
      <div class="panel">
        <span class="badge">Save & cook</span>
        <span class="cta-text">{{#if cta_text}}{{cta_text}}{{else}}{{#if cta_slide}}{{cta_slide.body}}{{/if}}{{/if}}</span>
        {{#if cta_handle}}<span class="cta-handle">{{cta_handle}}</span>{{else}}{{#if cta_slide.handle}}<span class="cta-handle">{{cta_slide.handle}}</span>{{/if}}{{/if}}
      </div>
    </div>
  </div>

</body>
</html>
