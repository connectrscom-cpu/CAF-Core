<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <title>Carousel — Big Word Duo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@600;700&family=Inter:wght@800;900&family=Outfit:wght@500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --safe: 80px;
      --ink: #0f0f14;
      --paper-lemon: #fff3b0;
      --paper-peach: #ffd6bf;
      --paper-mint: #cdeed8;
      --paper-sky: #cfe9ff;
      --paper-pink: #ffd4e1;
      --word-blue: #6fc6e0;
      --word-shade: #2f86a8;
      --word-pink: #ff7aa6;
      --word-shade-pink: #b04667;
      --accent: #0f0f14;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Outfit', sans-serif; background: #0f0f14; color: var(--ink); }
    .slide { width: 1080px; height: 1350px; overflow: hidden; flex-shrink: 0; position: relative; }
    .slide-inner {
      width: 100%; height: 100%;
      position: relative;
      padding: var(--safe) var(--safe) 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: center;
      text-align: center;
      background: var(--paper-lemon);
    }
    .slide:nth-of-type(5n+2) .slide-inner { background: var(--paper-peach); }
    .slide:nth-of-type(5n+3) .slide-inner { background: var(--paper-mint); }
    .slide:nth-of-type(5n+4) .slide-inner { background: var(--paper-sky); }
    .slide:nth-of-type(5n+5) .slide-inner { background: var(--paper-pink); }

    .top-headline {
      font-family: 'Inter', sans-serif;
      font-weight: 900;
      font-size: clamp(90px, 9.5vw, 116px);
      line-height: 1.02;
      letter-spacing: -0.025em;
      color: var(--ink);
      max-width: 920px;
      margin-top: 20px;
      z-index: 4;
      position: relative;
    }
    .body-copy {
      font-family: 'Outfit', sans-serif;
      font-weight: 500;
      font-size: clamp(44px, 4.4vw, 54px);
      line-height: 1.35;
      color: var(--ink);
      max-width: 820px;
      margin-top: 28px;
      z-index: 4;
      position: relative;
    }
    .tag {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 30px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink);
      opacity: 0.7;
      margin-top: 8px;
      z-index: 4;
      position: relative;
    }
    .cta-handle {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 44px;
      color: var(--ink);
      margin-top: 20px;
      z-index: 4;
      position: relative;
    }

    .stage {
      position: absolute;
      left: 0; right: 0; bottom: 0;
      height: 720px;
      z-index: 1;
      display: block;
    }

    .bigword-wrap { position: absolute; left: 50%; top: 55%; transform: translate(-50%, -50%); z-index: 2; pointer-events: none; }
    .bigword {
      font-family: 'Fredoka', sans-serif;
      font-weight: 700;
      font-size: 340px;
      line-height: 0.9;
      color: var(--word-blue);
      letter-spacing: -0.04em;
      text-transform: uppercase;
      text-shadow:
        6px 0 0 var(--word-shade),
        12px 0 0 var(--word-shade),
        18px 0 0 var(--word-shade),
        0 8px 0 var(--word-shade),
        12px 8px 0 var(--word-shade);
      -webkit-text-stroke: 4px var(--ink);
      white-space: nowrap;
    }
    .slide:nth-of-type(even) .bigword { color: var(--word-pink); text-shadow: 6px 0 0 var(--word-shade-pink), 12px 0 0 var(--word-shade-pink), 18px 0 0 var(--word-shade-pink), 0 8px 0 var(--word-shade-pink), 12px 8px 0 var(--word-shade-pink); }

    .char-left { position: absolute; left: 40px; bottom: 0; width: 360px; height: 720px; z-index: 3; }
    .char-right { position: absolute; right: 40px; bottom: 0; width: 360px; height: 720px; z-index: 3; }

    .hill {
      position: absolute;
      left: 0; right: 0;
      bottom: 0;
      height: 240px;
      background: radial-gradient(ellipse at 50% 120%, rgba(236,120,170,0.35) 0%, rgba(236,120,170,0.0) 70%);
      z-index: 0;
    }
  </style>
</head>
<body>
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <!-- Woman A: dark skin, red jacket, holding tote -->
      <symbol id="char-a" viewBox="0 0 360 720">
        <circle cx="180" cy="150" r="80" fill="#a26b4f" stroke="#0f0f14" stroke-width="5"/>
        <path d="M105 150 Q105 80 180 80 Q255 80 255 150 L248 140 Q225 115 180 115 Q135 115 112 140 Z" fill="#9ec6ff"/>
        <circle cx="158" cy="155" r="6" fill="#0f0f14"/>
        <circle cx="202" cy="155" r="6" fill="#0f0f14"/>
        <circle cx="158" cy="155" r="12" fill="none" stroke="#0f0f14" stroke-width="4"/>
        <circle cx="202" cy="155" r="12" fill="none" stroke="#0f0f14" stroke-width="4"/>
        <line x1="170" y1="155" x2="190" y2="155" stroke="#0f0f14" stroke-width="4"/>
        <path d="M165 190 Q180 200 195 190" stroke="#0f0f14" stroke-width="4" fill="none" stroke-linecap="round"/>
        <!-- body / jacket -->
        <path d="M80 260 Q180 240 280 260 L300 520 L60 520 Z" fill="#7a1e24" stroke="#0f0f14" stroke-width="5"/>
        <path d="M140 260 L140 420 L180 460 L220 420 L220 260" fill="#ffffff" stroke="#0f0f14" stroke-width="5"/>
        <!-- pants -->
        <rect x="90" y="515" width="80" height="170" fill="#0f0f14"/>
        <rect x="190" y="515" width="80" height="170" fill="#0f0f14"/>
        <rect x="80" y="680" width="100" height="30" fill="#7a61f5" stroke="#0f0f14" stroke-width="5" rx="10"/>
        <rect x="180" y="680" width="100" height="30" fill="#7a61f5" stroke="#0f0f14" stroke-width="5" rx="10"/>
        <!-- arm with bag -->
        <path d="M290 280 Q330 360 310 460" stroke="#a26b4f" stroke-width="28" fill="none" stroke-linecap="round"/>
        <rect x="275" y="440" width="100" height="120" fill="#0f0f14" rx="6"/>
        <path d="M285 440 Q325 400 365 440" stroke="#0f0f14" stroke-width="6" fill="none"/>
      </symbol>

      <!-- Woman B: pale skin, green skirt, holding basketball -->
      <symbol id="char-b" viewBox="0 0 360 720">
        <circle cx="180" cy="150" r="80" fill="#f2c6a0" stroke="#0f0f14" stroke-width="5"/>
        <path d="M100 150 Q100 80 180 80 Q260 80 260 150 L260 200 Q230 150 180 150 Q130 150 100 200 Z" fill="#2a2630"/>
        <circle cx="160" cy="158" r="5" fill="#0f0f14"/>
        <circle cx="200" cy="158" r="5" fill="#0f0f14"/>
        <circle cx="160" cy="158" r="14" fill="none" stroke="#0f0f14" stroke-width="4"/>
        <circle cx="200" cy="158" r="14" fill="none" stroke="#0f0f14" stroke-width="4"/>
        <line x1="174" y1="158" x2="186" y2="158" stroke="#0f0f14" stroke-width="4"/>
        <path d="M168 190 Q180 200 192 190" stroke="#0f0f14" stroke-width="4" fill="none" stroke-linecap="round"/>
        <!-- tank top -->
        <path d="M110 250 Q180 235 250 250 L240 360 L120 360 Z" fill="#0f0f14" stroke="#0f0f14" stroke-width="5"/>
        <!-- skirt -->
        <path d="M100 360 Q180 350 260 360 L280 540 L80 540 Z" fill="#6a9b6d" stroke="#0f0f14" stroke-width="5"/>
        <!-- legs -->
        <rect x="120" y="535" width="50" height="150" fill="#f2c6a0"/>
        <rect x="190" y="535" width="50" height="150" fill="#f2c6a0"/>
        <!-- shoes -->
        <rect x="110" y="680" width="70" height="30" fill="#0f0f14" rx="10"/>
        <rect x="180" y="680" width="70" height="30" fill="#0f0f14" rx="10"/>
        <!-- arm with basketball -->
        <path d="M100 280 Q60 340 90 420" stroke="#f2c6a0" stroke-width="28" fill="none" stroke-linecap="round"/>
        <circle cx="72" cy="440" r="52" fill="#ff8a3d" stroke="#0f0f14" stroke-width="5"/>
        <path d="M72 390 L72 490 M22 440 L122 440 M36 400 Q72 440 108 400 M36 480 Q72 440 108 480" stroke="#0f0f14" stroke-width="4" fill="none"/>
      </symbol>

      <!-- Hills / plants behind characters -->
      <symbol id="plants" viewBox="0 0 1080 320" preserveAspectRatio="xMidYMax slice">
        <ellipse cx="540" cy="320" rx="560" ry="120" fill="rgba(236,120,170,0.35)"/>
        <ellipse cx="180" cy="320" rx="260" ry="70" fill="rgba(236,120,170,0.45)"/>
        <ellipse cx="900" cy="320" rx="260" ry="70" fill="rgba(236,120,170,0.45)"/>
      </symbol>
    </defs>
  </svg>

  <div class="slide cover">
    <div class="slide-inner">
      {{#if cover_slide.body}}<div class="tag">{{cover_slide.body}}</div>{{/if}}
      <div class="top-headline">{{#if cover}}{{cover}}{{else}}{{cover_slide.headline}}{{/if}}</div>
      <svg class="stage" viewBox="0 0 1080 720" preserveAspectRatio="xMidYMax slice">
        <use href="#plants" x="0" y="400"/>
      </svg>
      <div class="bigword-wrap"><div class="bigword">FIGHT</div></div>
      <svg class="char-left"><use href="#char-a"/></svg>
      <svg class="char-right"><use href="#char-b"/></svg>
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <div class="top-headline">{{headline}}</div>
      {{#if body}}<p class="body-copy">{{body}}</p>{{/if}}
      <svg class="stage" viewBox="0 0 1080 720" preserveAspectRatio="xMidYMax slice">
        <use href="#plants" x="0" y="400"/>
      </svg>
      <svg class="char-left"><use href="#char-a"/></svg>
      <svg class="char-right"><use href="#char-b"/></svg>
    </div>
  </div>
  {{/each}}

  <div class="slide">
    <div class="slide-inner">
      <div class="tag">Join us</div>
      <div class="top-headline">{{#if cta_text}}{{cta_text}}{{else}}{{cta_slide.body}}{{/if}}</div>
      {{#if cta_handle}}<div class="cta-handle">{{cta_handle}}</div>{{else}}{{#if cta_slide.handle}}<div class="cta-handle">{{cta_slide.handle}}</div>{{/if}}{{/if}}
      <svg class="stage" viewBox="0 0 1080 720" preserveAspectRatio="xMidYMax slice">
        <use href="#plants" x="0" y="400"/>
      </svg>
      <div class="bigword-wrap"><div class="bigword">GO</div></div>
      <svg class="char-left"><use href="#char-a"/></svg>
      <svg class="char-right"><use href="#char-b"/></svg>
    </div>
  </div>
</body>
</html>
