<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --safe: 84px;
      /* Warm cream + honey gold — cohesive with Sign & Sound golden palette */
      --bg1:#f5efe6;
      --bg2:#e8ddca;
      --text:#2a2318;
      --muted:#6b5e4d;
      --panel: rgba(255,252,247,0.92);
      --border: rgba(92,72,38,0.14);
      --sent: #e6d4b3;
      --sent-border: rgba(138,106,48,0.18);
      --accent:#8f6b28;
      --accent-light:#c9a75a;
      --radius: 48px;
    }
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:Inter,system-ui,Arial,sans-serif;background:linear-gradient(180deg,var(--bg1),var(--bg2));color:var(--text);}
    .slide{
      width:1080px;height:1350px;overflow:hidden;flex-shrink:0;
      background:
        radial-gradient(ellipse 90% 55% at 50% -10%, rgba(201,167,90,0.18), transparent 50%),
        linear-gradient(180deg,var(--bg1),var(--bg2));
      border:1px solid rgba(92,72,38,0.10);
    }
    .outer{
      width:100%;height:100%;
      padding:var(--safe);
      display:flex;flex-direction:column;justify-content:center;
    }
    .frame{
      background:var(--panel);
      border:1px solid var(--border);
      border-radius: var(--radius);
      height: 100%;
      padding: 34px;
      display:flex;
      flex-direction:column;
      gap: 22px;
      box-shadow: 0 26px 70px rgba(58,42,22,0.12);
    }
    .top{
      display:flex;align-items:center;gap:14px;
      padding-bottom: 18px;
      border-bottom:1px solid rgba(92,72,38,0.12);
    }
    .avatar{
      width:52px;height:52px;border-radius:50%;
      background:linear-gradient(145deg,var(--accent-light),var(--accent));
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.35);
    }
    .name{
      font-weight:800;font-size:30px;letter-spacing:-0.02em;
      overflow-wrap:anywhere;word-break:break-word;max-width:100%;
    }
    .status{font-size:22px;color:var(--muted);margin-top:4px;}
    .bubble{
      max-width: 92%;
      padding: 18px 20px;
      border-radius: 26px;
      font-size: 44px;
      line-height: 1.3;
      border: 1px solid rgba(92,72,38,0.12);
      box-shadow: 0 10px 26px rgba(58,42,22,0.08);
      text-align: left;
      overflow-wrap: anywhere;
      word-break: break-word;
      hyphens: auto;
    }
    .recv{ background: #fffcf7; align-self:flex-start; border-top-left-radius: 10px; }
    .sent{ background: var(--sent); border-color: var(--sent-border); align-self:flex-end; border-top-right-radius: 10px; color: var(--text); }
    .kicker{
      font-size:18px;
      letter-spacing:0.18em;
      text-transform:uppercase;
      color:rgba(107,94,77,0.72);
    }
    .final{
      height:100%;
      display:flex;
      flex-direction:column;
      justify-content:center;
      align-items:center;
      text-align:center;
      gap:18px;
    }
    .final h1{
      font-size:clamp(36px, 6.2vw, 70px);
      line-height:1.08;
      letter-spacing:-0.04em;
      font-weight:800;
      max-width: 920px;
      overflow-wrap:anywhere;
      word-break:break-word;
      hyphens:auto;
    }
    .final p{
      font-size:40px;
      line-height:1.35;
      color:var(--muted);
      max-width: 920px;
      overflow-wrap:anywhere;
      word-break:break-word;
    }

    /* Keep title/body visually grouped on cover + CTA (avoid "body at bottom"). */
    .frame{ justify-content: flex-start; }
    .final{ justify-content: flex-start; }
  </style>
</head>
<body>
  <!-- Cover as chat setup -->
  <div class="slide">
    <div class="outer">
      <div class="frame">
        <div class="top">
          <div class="avatar"></div>
          <div>
            {{!-- Cover header: brand/project only (LLM often misuses cover_slide.name for hook copy). --}}
            <div class="name">{{#if project_display_name}}{{project_display_name}}{{else}}{{#if handle}}{{handle}}{{else}}SNS{{/if}}{{/if}}</div>
            <div class="status">{{#if cover_slide.status}}{{cover_slide.status}}{{else}}online{{/if}}</div>
          </div>
        </div>
        <div class="bubble recv">
          {{#if cover}}{{cover}}{{else}}{{#if cover_slide}}{{cover_slide.headline}}{{else}}{{intro_title}}{{/if}}{{/if}}
        </div>
        {{#if cover_subtitle}}<div class="bubble sent">{{cover_subtitle}}</div>{{else}}{{#if cover_slide.body}}<div class="bubble sent">{{cover_slide.body}}</div>{{/if}}{{/if}}
        <!-- Removed fixed "Swipe" bubble; it often pushes copy down and reads as template filler. -->
      </div>
    </div>
  </div>

  <!-- Body slides as threaded beats -->
  {{#each body_slides}}
  <div class="slide">
    <div class="outer">
      <div class="frame">
        <div class="top">
          <div class="avatar"></div>
          <div>
            <div class="name">{{#if name}}{{name}}{{else}}{{#if handle}}{{handle}}{{else}}SNS{{/if}}{{/if}}</div>
            <div class="status">{{#if status}}{{status}}{{else}}typing...{{/if}}</div>
          </div>
        </div>
        <div class="bubble recv">{{headline}}</div>
        <div class="bubble sent">{{body}}</div>
      </div>
    </div>
  </div>
  {{/each}}

  <!-- CTA -->
  <div class="slide">
    <div class="outer">
      <div class="frame">
        <div class="final">
          <div class="kicker">{{#if cta_slide.kicker}}{{cta_slide.kicker}}{{else}}Final slide{{/if}}</div>
          <h1>{{#if cta_text}}{{cta_text}}{{else}}{{#if cta_slide}}{{cta_slide.body}}{{/if}}{{/if}}</h1>
          {{#if cta_handle}}<p>{{cta_handle}}</p>{{else}}{{#if cta_slide.handle}}<p>{{cta_slide.handle}}</p>{{/if}}{{/if}}
        </div>
      </div>
    </div>
  </div>
</body>
</html>
