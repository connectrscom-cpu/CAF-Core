<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <title>Cuisina — Pesto Fresco</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
  <style>
    :root {
      --basil: #1d4e3e;
      --basil-light: #2d6a4f;
      --parm: #f8f4e8;
      --oil: #a8d5ba;
      --garlic: #e8f0e4;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Be Vietnam Pro', sans-serif; background: #0c1814; color: #0f221a; }
    .slide { width: 1080px; height: 1350px; overflow: hidden; flex-shrink: 0; }
    .slide-inner {
      width: 100%; height: 100%; position: relative;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 74px 62px;
      text-align: center;
      background: radial-gradient(circle at 20% 20%, rgba(168,213,186,0.35) 0%, transparent 45%),
        radial-gradient(circle at 85% 75%, rgba(45,106,79,0.5) 0%, transparent 42%),
        linear-gradient(160deg, var(--basil) 0%, #12382c 55%, #0a2019 100%);
    }
    .swirl {
      position: absolute; width: 500px; height: 500px;
      border-radius: 50%;
      background: conic-gradient(from 40deg, rgba(168,213,186,0.15), transparent 40%, rgba(45,106,79,0.2), transparent 80%);
      top: -10%; right: -15%; pointer-events: none;
    }
    .sheet {
      position: relative; z-index: 2; max-width: 880px;
      padding: 48px 50px 52px;
      border-radius: 32px 8px 32px 8px;
      background: linear-gradient(165deg, var(--parm) 0%, var(--garlic) 100%);
      box-shadow: 0 30px 75px rgba(0,0,0,0.42);
      border: 1px solid rgba(29,78,62,0.15);
    }
    .title-text {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(58px, 6.2vw, 82px);
      font-weight: 400;
      color: var(--basil);
      line-height: 1.08;
      font-style: italic;
    }
    .subtitle-text {
      font-family: 'Be Vietnam Pro', sans-serif;
      font-size: clamp(30px, 3.1vw, 38px);
      color: var(--basil-light);
      margin-top: 20px;
      font-weight: 600;
      font-style: normal;
    }
    .body-title {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(46px, 4.8vw, 62px);
      color: var(--basil);
      margin-bottom: 24px;
      line-height: 1.1;
    }
    .body-text {
      font-family: 'Be Vietnam Pro', sans-serif;
      font-size: clamp(33px, 3.3vw, 41px);
      line-height: 1.43;
      color: #1a2e22;
      max-width: 750px;
    }
    .cta-text {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(54px, 5.8vw, 76px);
      color: var(--basil);
      font-style: italic;
    }
    .cta-handle {
      font-family: 'Be Vietnam Pro', sans-serif;
      font-size: clamp(32px, 3.2vw, 40px);
      color: var(--basil-light);
      margin-top: 16px;
      font-weight: 600;
    }
    .label {
      font-size: 12px; letter-spacing: 0.32em; text-transform: uppercase;
      color: var(--basil-light); margin-bottom: 14px; font-weight: 600;
    }
  </style>
</head>
<body>

  <div class="slide">
    <div class="slide-inner">
      <span class="swirl"></span>
      <div class="sheet">
        <div class="label">Basil · pine nut · parm</div>
        <span class="title-text">{{#if cover}}{{cover}}{{else}}{{#if cover_slide}}{{cover_slide.headline}}{{else}}{{intro_title}}{{/if}}{{/if}}</span>
        {{#if cover_subtitle}}<span class="subtitle-text">{{cover_subtitle}}</span>{{else}}{{#if cover_slide.body}}<span class="subtitle-text">{{cover_slide.body}}</span>{{/if}}{{/if}}
      </div>
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <div class="sheet">
        <span class="body-title">{{headline}}</span>
        <p class="body-text">{{body}}</p>
      </div>
    </div>
  </div>
  {{/each}}

  <div class="slide">
    <div class="slide-inner">
      <span class="swirl"></span>
      <div class="sheet">
        <div class="label">Mangia</div>
        <span class="cta-text">{{#if cta_text}}{{cta_text}}{{else}}{{#if cta_slide}}{{cta_slide.body}}{{/if}}{{/if}}</span>
        {{#if cta_handle}}<span class="cta-handle">{{cta_handle}}</span>{{else}}{{#if cta_slide.handle}}<span class="cta-handle">{{cta_slide.handle}}</span>{{/if}}{{/if}}
      </div>
    </div>
  </div>

</body>
</html>
