<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=1080, height=1350" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --paper:#fbfcfe;
      --ink:#0b1320;
      --muted:#334155;
      --stroke: rgba(15, 23, 42, 0.10);
      --accent:#2563eb;
      --accent2:#22c55e;
      --pad:86px;
      --r:28px;
    }
    *{ box-sizing:border-box; margin:0; padding:0; }
    body{
      background: var(--paper);
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      -webkit-font-smoothing: antialiased;
      color: var(--ink);
    }
    .slide{
      width:1080px; height:1350px; overflow:hidden; position:relative;
      padding: var(--pad);
      background: var(--paper);
    }
    .corner{
      position:absolute; inset:-2px;
      background:
        radial-gradient(520px 520px at 92% 10%, rgba(37,99,235,0.12) 0%, rgba(37,99,235,0.03) 35%, rgba(0,0,0,0) 60%),
        radial-gradient(560px 560px at 14% 86%, rgba(34,197,94,0.10) 0%, rgba(34,197,94,0.03) 38%, rgba(0,0,0,0) 62%);
      pointer-events:none;
    }
    .page{ position:relative; z-index:1; height: calc(1350px - var(--pad)*2); display:flex; flex-direction:column; }
    .meta{
      display:flex; gap:10px; align-items:center; justify-content:space-between;
      margin-bottom: 26px;
    }
    .badge{
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(11,19,32,0.78);
    }
    .progress{
      font-size: 18px;
      font-weight: 700;
      color: rgba(11,19,32,0.62);
    }
    .rule{
      height: 6px;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      margin: 10px 0 34px;
      opacity: 0.88;
    }
    .headline{
      font-weight: 800;
      font-size: 84px;
      line-height: 1.05;
      letter-spacing: -0.03em;
      overflow-wrap:anywhere;
      word-break:break-word;
      max-width: 900px;
    }
    .body{
      margin-top: 22px;
      font-weight: 500;
      font-size: 36px;
      line-height: 1.48;
      color: rgba(51,65,85,0.92);
      white-space: pre-wrap;
      overflow-wrap:anywhere;
      word-break:break-word;
      max-width: 920px;
    }
    .panel{
      margin-top:auto;
      border: 1px solid var(--stroke);
      border-radius: var(--r);
      background: rgba(255,255,255,0.72);
      box-shadow: 0 12px 40px rgba(15,23,42,0.08);
      padding: 28px 28px 26px;
    }
    .panel h3{
      font-size: 22px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(11,19,32,0.70);
      margin-bottom: 10px;
    }
    .panel p{
      font-size: 28px;
      line-height: 1.45;
      color: rgba(51,65,85,0.96);
      white-space: pre-wrap;
    }
    .cta .headline{ font-size: 96px; }
    .cta .body{ font-size: 40px; color: rgba(51,65,85,0.96); }
    .handle{
      margin-top: 16px;
      font-size: 38px;
      font-weight: 800;
      color: rgba(11,19,32,0.90);
    }
  </style>
</head>
<body>
  <div class="slide cover">
    <div class="corner"></div>
    <div class="page">
      <div class="meta">
        <div class="badge">{{#if cover_slide.badge}}{{cover_slide.badge}}{{else}}Cover{{/if}}</div>
        <div class="progress">{{slide_index}} / {{slide_total}}</div>
      </div>
      <div class="rule"></div>
      <div class="headline">{{joinEmojiOrphans cover_slide.headline}}</div>
      {{#if cover_slide.body}}<div class="body">{{joinEmojiOrphans cover_slide.body}}</div>{{/if}}
      <div class="panel">
        <h3>{{#if cover_slide.panel_title}}{{cover_slide.panel_title}}{{else}}Quick note{{/if}}</h3>
        <p>{{#if cover_slide.panel_body}}{{joinEmojiOrphans cover_slide.panel_body}}{{else}}Save this. You’ll want it when you’re overthinking later.{{/if}}</p>
      </div>
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide body-slide">
    <div class="corner"></div>
    <div class="page">
      <div class="meta">
        <div class="badge">{{#if badge}}{{badge}}{{else}}Body{{/if}}</div>
        <div class="progress">{{../slide_index}} / {{../slide_total}}</div>
      </div>
      <div class="rule"></div>
      <div class="headline" style="font-size:72px">{{joinEmojiOrphans headline}}</div>
      <div class="body">{{joinEmojiOrphans body}}</div>
      <div class="panel">
        <h3>{{#if panel_title}}{{panel_title}}{{else}}Micro-action{{/if}}</h3>
        <p>{{#if panel_body}}{{joinEmojiOrphans panel_body}}{{else}}Underline the one line that felt “too real”. Then name the need underneath it.{{/if}}</p>
      </div>
    </div>
  </div>
  {{/each}}

  <div class="slide cta">
    <div class="corner"></div>
    <div class="page">
      <div class="meta">
        <div class="badge">{{#if cta_slide.badge}}{{cta_slide.badge}}{{else}}CTA{{/if}}</div>
        <div class="progress">{{slide_index}} / {{slide_total}}</div>
      </div>
      <div class="rule"></div>
      <div class="headline">{{#if cta_text}}{{joinEmojiOrphans cta_text}}{{else}}{{joinEmojiOrphans cta_slide.body}}{{/if}}</div>
      {{#if cta_slide.sub}}<div class="body">{{joinEmojiOrphans cta_slide.sub}}</div>{{/if}}
      {{#if cta_handle}}<div class="handle">{{cta_handle}}</div>{{else}}{{#if cta_slide.handle}}<div class="handle">{{cta_slide.handle}}</div>{{/if}}{{/if}}
      <div class="panel">
        <h3>{{#if cta_slide.panel_title}}{{cta_slide.panel_title}}{{else}}Reply{{/if}}</h3>
        <p>{{#if cta_slide.panel_body}}{{joinEmojiOrphans cta_slide.panel_body}}{{else}}Comment your sign + the pattern you’re trying to break.{{/if}}</p>
      </div>
    </div>
  </div>
</body>
</html>

