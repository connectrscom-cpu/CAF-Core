<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <title>Cuisina — Matcha Bistro</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600&family=Playfair+Display:ital,wght@0,600;1,500&display=swap" rel="stylesheet">
  <style>
    :root {
      --matcha: #88b04b;
      --matcha-deep: #5f7434;
      --foam: #f7f5f0;
      --stone: #2c2a26;
      --accent: #c4d93a;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Outfit', sans-serif; background: #141210; color: var(--stone); }
    .slide { width: 1080px; height: 1350px; overflow: hidden; flex-shrink: 0; }
    .slide-inner {
      width: 100%; height: 100%; position: relative;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 80px 60px;
      text-align: center;
      background:
        radial-gradient(ellipse 90% 55% at 50% -10%, rgba(196,217,58,0.35) 0%, transparent 55%),
        linear-gradient(185deg, #3d4a2a 0%, #2a3220 45%, #1a1e14 100%);
    }
    .whisk {
      position: absolute; width: 340px; height: 340px;
      border: 2px dashed rgba(247,245,240,0.12);
      border-radius: 50%; pointer-events: none;
      top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(12deg);
    }
    .box {
      position: relative; z-index: 2; max-width: 860px;
      padding: 44px 46px 48px;
      border-radius: 20px;
      background: rgba(247,245,240,0.97);
      box-shadow: 0 32px 80px rgba(0,0,0,0.38);
      border: 1px solid rgba(136,176,75,0.25);
    }
    .title-text {
      font-family: 'Playfair Display', serif;
      font-size: clamp(56px, 6vw, 78px);
      font-weight: 600;
      color: var(--matcha-deep);
      line-height: 1.12;
    }
    .subtitle-text {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(30px, 3.1vw, 38px);
      color: var(--matcha);
      margin-top: 18px;
      font-weight: 500;
    }
    .body-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(46px, 4.8vw, 60px);
      color: var(--matcha-deep);
      margin-bottom: 22px;
    }
    .body-text {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(33px, 3.3vw, 41px);
      line-height: 1.44;
      color: #3a3830;
      max-width: 740px;
    }
    .cta-text {
      font-family: 'Playfair Display', serif;
      font-size: clamp(54px, 5.6vw, 72px);
      font-weight: 600;
      color: var(--matcha-deep);
    }
    .cta-handle {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(32px, 3.2vw, 40px);
      color: var(--matcha);
      margin-top: 14px;
      font-weight: 600;
    }
    .tag {
      font-size: 11px; letter-spacing: 0.4em; text-transform: uppercase;
      color: var(--matcha); margin-bottom: 14px; font-weight: 600;
    }
  </style>
</head>
<body>

  <div class="slide">
    <div class="slide-inner">
      <span class="whisk"></span>
      <div class="box">
        <div class="tag">Whisked · plated</div>
        <span class="title-text">{{#if cover}}{{cover}}{{else}}{{#if cover_slide}}{{cover_slide.headline}}{{else}}{{intro_title}}{{/if}}{{/if}}</span>
        {{#if cover_subtitle}}<span class="subtitle-text">{{cover_subtitle}}</span>{{else}}{{#if cover_slide.body}}<span class="subtitle-text">{{cover_slide.body}}</span>{{/if}}{{/if}}
      </div>
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <div class="box">
        <span class="body-title">{{headline}}</span>
        <p class="body-text">{{body}}</p>
      </div>
    </div>
  </div>
  {{/each}}

  <div class="slide">
    <div class="slide-inner">
      <span class="whisk"></span>
      <div class="box">
        <div class="tag">Your next bite</div>
        <span class="cta-text">{{#if cta_text}}{{cta_text}}{{else}}{{#if cta_slide}}{{cta_slide.body}}{{/if}}{{/if}}</span>
        {{#if cta_handle}}<span class="cta-handle">{{cta_handle}}</span>{{else}}{{#if cta_slide.handle}}<span class="cta-handle">{{cta_slide.handle}}</span>{{/if}}{{/if}}
      </div>
    </div>
  </div>

</body>
</html>
