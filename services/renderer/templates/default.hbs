<!DOCTYPE html>
<html><head>
<style>
  body { margin: 0; padding: 0; background: #111; font-family: system-ui, sans-serif; }
  .slide { width: 1080px; height: 1350px; display: flex; flex-direction: column; align-items: flex-start; justify-content: flex-start; padding: 110px 88px 88px; box-sizing: border-box; background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); color: #fff; }
  .slide h1 { font-size: 64px; font-weight: 850; text-align: left; line-height: 1.16; margin: 0 0 28px 0; letter-spacing: -0.01em; max-width: 860px; }
  .slide p { font-size: 34px; font-weight: 520; text-align: left; opacity: 0.96; line-height: 1.45; margin: 0; max-width: 860px; white-space: pre-wrap; color: rgba(255,255,255,0.96); }
  .cta-handle { margin-top: 18px; font-size: 34px; font-weight: 750; opacity: 0.98; }
</style>
</head><body>
{{#if cover_slide}}
<div class="slide">
  <h1>{{cover_slide.headline}}</h1>
  {{#if cover_slide.body}}<p>{{cover_slide.body}}</p>{{/if}}
</div>
{{/if}}
{{#each body_slides}}
<div class="slide">
  <h1>{{this.headline}}</h1>
  {{#if this.body}}<p>{{this.body}}</p>{{/if}}
</div>
{{/each}}
{{#if cta_slide}}
<div class="slide">
  <h1>{{#if cta_text}}{{cta_text}}{{else}}{{cta_slide.body}}{{/if}}</h1>
  {{#if cta_handle}}<div class="cta-handle">{{cta_handle}}</div>{{else}}{{#if cta_slide.handle}}<div class="cta-handle">{{cta_slide.handle}}</div>{{/if}}{{/if}}
</div>
{{/if}}
</body></html>
