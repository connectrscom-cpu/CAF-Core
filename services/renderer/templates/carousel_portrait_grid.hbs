<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <title>Carousel — Portrait Grid</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Outfit:wght@500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --safe: 70px;
      --ink: #0f0f14;
      --paper-pink: #ffb8c6;
      --paper-coral: #ffc2b0;
      --paper-sky: #cfe9ff;
      --paper-mint: #c8eed4;
      --paper-cream: #fff3c8;
      --box: #0f0f14;
      --box-ink: #ffffff;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Outfit', sans-serif; background: #0f0f14; }
    .slide { width: 1080px; height: 1350px; overflow: hidden; flex-shrink: 0; position: relative; }
    .slide-inner {
      width: 100%; height: 100%;
      position: relative;
      padding: var(--safe) var(--safe) 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      background: var(--paper-pink);
    }
    .slide:nth-of-type(5n+2) .slide-inner { background: var(--paper-coral); }
    .slide:nth-of-type(5n+3) .slide-inner { background: var(--paper-sky); }
    .slide:nth-of-type(5n+4) .slide-inner { background: var(--paper-mint); }
    .slide:nth-of-type(5n+5) .slide-inner { background: var(--paper-cream); }

    .title-block {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      margin-top: 20px;
      z-index: 3;
      position: relative;
    }
    .box {
      display: inline-block;
      padding: 14px 26px;
      font-family: 'Archivo Black', sans-serif;
      font-size: clamp(64px, 6.8vw, 84px);
      line-height: 1.0;
      text-transform: uppercase;
      letter-spacing: -0.01em;
      color: var(--box-ink);
      background: var(--box);
      max-width: 920px;
      word-break: break-word;
    }
    .tag {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 30px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink);
      opacity: 0.7;
      margin-bottom: 6px;
    }
    .body-copy {
      font-family: 'Outfit', sans-serif;
      font-weight: 500;
      font-size: 42px;
      line-height: 1.35;
      color: var(--ink);
      margin-top: 18px;
      max-width: 820px;
      z-index: 3;
      position: relative;
    }
    .cta-handle {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 42px;
      color: var(--ink);
      margin-top: 12px;
      z-index: 3;
      position: relative;
    }

    .grid {
      position: absolute;
      left: 0; right: 0;
      bottom: 0;
      width: 100%;
      height: 820px;
      z-index: 1;
      display: block;
    }
  </style>
</head>
<body>
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <!-- Reusable portrait: head + shoulders with configurable fills -->
      <symbol id="portrait" viewBox="0 0 200 260">
        <!-- shoulders -->
        <path d="M10 260 Q100 180 190 260 Z" fill="var(--p-top, #ffb8a0)" stroke="#0f0f14" stroke-width="4"/>
        <!-- neck -->
        <rect x="85" y="155" width="30" height="35" fill="var(--p-skin, #f2c6a0)"/>
        <!-- face -->
        <ellipse cx="100" cy="125" rx="58" ry="70" fill="var(--p-skin, #f2c6a0)" stroke="#0f0f14" stroke-width="4"/>
        <!-- hair -->
        <path d="M42 125 Q42 50 100 50 Q158 50 158 125 L158 150 Q140 110 100 110 Q60 110 42 150 Z" fill="var(--p-hair, #0f0f14)"/>
        <!-- eyes -->
        <path d="M80 130 Q85 122 92 130" stroke="#0f0f14" stroke-width="3" fill="none" stroke-linecap="round"/>
        <path d="M108 130 Q115 122 120 130" stroke="#0f0f14" stroke-width="3" fill="none" stroke-linecap="round"/>
        <!-- mouth -->
        <path d="M88 160 Q100 168 112 160" stroke="#0f0f14" stroke-width="3" fill="none" stroke-linecap="round"/>
        <!-- choker -->
        <rect x="72" y="190" width="56" height="6" fill="#0f0f14"/>
      </symbol>

      <!-- Grid of 11 portraits (2 rows staggered) matching the reference composition -->
      <symbol id="portrait-grid" viewBox="0 0 1080 820" preserveAspectRatio="xMidYMax slice">
        <!-- back row -->
        <g transform="translate(10,120)"    style="--p-skin:#f2c6a0; --p-hair:#ffc9d0; --p-top:#d85a6e">   <use href="#portrait"/></g>
        <g transform="translate(180,60)"    style="--p-skin:#f2c6a0; --p-hair:#c8d6ff; --p-top:#4a62ff">   <use href="#portrait"/></g>
        <g transform="translate(360,100)"   style="--p-skin:#d89a74; --p-hair:#e7b55c; --p-top:#2a3cff">   <use href="#portrait"/></g>
        <g transform="translate(540,40)"    style="--p-skin:#a26b4f; --p-hair:#c74b3c; --p-top:#ff5b8a">   <use href="#portrait"/></g>
        <g transform="translate(720,80)"    style="--p-skin:#f2c6a0; --p-hair:#ffe6a0; --p-top:#2f7b5a">   <use href="#portrait"/></g>
        <g transform="translate(900,130)"   style="--p-skin:#c78b6a; --p-hair:#0f0f14; --p-top:#ff8a3d">   <use href="#portrait"/></g>
        <!-- front row -->
        <g transform="translate(70,360)"    style="--p-skin:#d89a74; --p-hair:#f5b1c6; --p-top:#ffb0c4">   <use href="#portrait"/></g>
        <g transform="translate(260,340)"   style="--p-skin:#f2c6a0; --p-hair:#c8d6ff; --p-top:#3a52c4">   <use href="#portrait"/></g>
        <g transform="translate(450,400)"   style="--p-skin:#8e5a42; --p-hair:#e7b55c; --p-top:#6a3dff">   <use href="#portrait"/></g>
        <g transform="translate(640,340)"   style="--p-skin:#623f2b; --p-hair:#0f0f14; --p-top:#00b8a4">   <use href="#portrait"/></g>
        <g transform="translate(830,370)"   style="--p-skin:#d89a74; --p-hair:#0f0f14; --p-top:#2a2630">   <use href="#portrait"/></g>
      </symbol>
    </defs>
  </svg>

  <div class="slide cover">
    <div class="slide-inner">
      <div class="title-block">
        {{#if cover_slide.body}}<div class="tag">{{cover_slide.body}}</div>{{/if}}
        <span class="box">{{#if cover}}{{cover}}{{else}}{{cover_slide.headline}}{{/if}}</span>
      </div>
      <svg class="grid"><use href="#portrait-grid"/></svg>
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <div class="title-block">
        <span class="box">{{headline}}</span>
      </div>
      {{#if body}}<p class="body-copy">{{body}}</p>{{/if}}
      <svg class="grid"><use href="#portrait-grid"/></svg>
    </div>
  </div>
  {{/each}}

  <div class="slide">
    <div class="slide-inner">
      <div class="title-block">
        <span class="box">{{#if cta_text}}{{cta_text}}{{else}}{{cta_slide.body}}{{/if}}</span>
        {{#if cta_handle}}<div class="cta-handle">{{cta_handle}}</div>{{else}}{{#if cta_slide.handle}}<div class="cta-handle">{{cta_slide.handle}}</div>{{/if}}{{/if}}
      </div>
      <svg class="grid"><use href="#portrait-grid"/></svg>
    </div>
  </div>
</body>
</html>
