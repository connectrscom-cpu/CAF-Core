<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --safe: 92px;
      --bg1:#0b0b16;
      --bg2:#14142a;
      --text:#f5f5f7;
      --muted:#b7b7c2;
      --accent:#9b5cff;
      --border: rgba(255,255,255,0.10);
    }
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:Inter,system-ui,Arial,sans-serif;background:linear-gradient(180deg,var(--bg1),var(--bg2));color:var(--text);}
    .slide{
      width:1080px;height:1350px;overflow:hidden;flex-shrink:0;
      background:
        radial-gradient(circle at 50% 50%, rgba(155,92,255,0.22), transparent 24%),
        radial-gradient(circle at 18% 22%, rgba(255,255,255,0.14), transparent 2%),
        radial-gradient(circle at 78% 72%, rgba(255,255,255,0.12), transparent 2%),
        linear-gradient(180deg,var(--bg1),var(--bg2));
      border:1px solid rgba(255,255,255,0.08);
    }
    .inner{
      width:100%;height:100%;
      padding:var(--safe);
      position:relative;
      display:flex;flex-direction:column;justify-content:space-between;
    }
    .kicker{
      font-size:18px;
      letter-spacing:0.18em;
      text-transform:uppercase;
      color:var(--muted);
    }
    .title{
      margin-top: 26px;
      font-size:88px;
      line-height:0.98;
      letter-spacing:-0.04em;
      font-weight:800;
      max-width: 920px;
    }
    .body{
      font-size:44px;
      line-height:1.32;
      color:var(--muted);
      max-width: 920px;
    }
    .orbit{
      width:560px;height:560px;border-radius:50%;
      border:1px solid rgba(255,255,255,0.10);
      position:absolute;
      left:50%;top:52%;
      transform:translate(-50%,-50%);
      pointer-events:none;
    }
    .orbit::before,.orbit::after{
      content:"";position:absolute;inset:56px;border-radius:50%;
      border:1px solid rgba(255,255,255,0.10);
    }
    .orbit::after{ inset:126px; }
    .glyph{
      width:170px;height:170px;border-radius:50%;
      display:grid;place-items:center;
      font-size:76px;font-weight:700;
      border:1px solid rgba(255,255,255,0.16);
      background: radial-gradient(circle, rgba(255,255,255,0.10), rgba(255,255,255,0.02));
      backdrop-filter: blur(10px);
      box-shadow: 0 30px 80px rgba(0,0,0,0.45);
    }
    .label{
      position:absolute;
      padding:14px 18px;
      border-radius:999px;
      font-size:18px;
      letter-spacing:0.16em;
      text-transform:uppercase;
      background: rgba(255,255,255,0.06);
      border:1px solid rgba(255,255,255,0.10);
      color:var(--muted);
    }
    .accent{ color: var(--accent); }
    .cta{
      font-weight:800;
      font-size:84px;
      line-height:0.98;
      letter-spacing:-0.04em;
      max-width: 920px;
    }
    .handle{
      margin-top:18px;
      font-weight:700;
      font-size:40px;
      letter-spacing:0.06em;
      color:rgba(245,245,247,0.9);
    }
  </style>
</head>
<body>
  <!-- Cover -->
  <div class="slide">
    <div class="inner" style="text-align:left;">
      <div class="orbit"></div>
      <div class="label" style="top:64px;left:64px;">{{#if cover_slide.label_left}}{{cover_slide.label_left}}{{else}}Sun{{/if}}</div>
      <div class="label" style="top:64px;right:64px;">{{#if cover_slide.label_right}}{{cover_slide.label_right}}{{else}}Moon{{/if}}</div>
      <div class="label" style="bottom:84px;left:50%;transform:translateX(-50%);">{{#if cover_slide.label_bottom}}{{cover_slide.label_bottom}}{{else}}Rising{{/if}}</div>
      <div>
        <div class="kicker">{{#if cover_slide.kicker}}{{cover_slide.kicker}}{{else}}Slide 01 / Identity{{/if}}</div>
        <div class="title" style="font-size:78px;line-height:1.02;margin-top:22px;max-width:900px;">
          {{#if cover}}{{cover}}{{else}}{{#if cover_slide}}{{cover_slide.headline}}{{else}}{{intro_title}}{{/if}}{{/if}}
        </div>
        <div class="body" style="margin-top:18px;max-width:820px;">
          {{#if cover_subtitle}}{{cover_subtitle}}{{else}}{{#if cover_slide}}{{cover_slide.body}}{{/if}}{{/if}}
        </div>
      </div>
      <div style="display:flex;justify-content:center;align-items:center;flex:1;">
        <div class="glyph">{{#if cover_slide.glyph}}{{cover_slide.glyph}}{{else}}✦{{/if}}</div>
      </div>
    </div>
  </div>

  <!-- Body -->
  {{#each body_slides}}
  <div class="slide">
    <div class="inner">
      <div>
        <div class="title">{{headline}}</div>
        <div class="body" style="margin-top: 18px; max-width: 860px;">{{body}}</div>
      </div>
      <div style="display:flex;justify-content:flex-end;align-items:flex-end;">
        <div class="glyph" style="width:140px;height:140px;font-size:62px;">
          {{#if glyph}}{{glyph}}{{else}}☾{{/if}}
        </div>
      </div>
    </div>
  </div>
  {{/each}}

  <!-- CTA -->
  <div class="slide">
    <div class="inner">
      <div>
        <div class="kicker">{{#if cta_slide.kicker}}{{cta_slide.kicker}}{{else}}Final / CTA{{/if}}</div>
        <div class="cta"><span class="accent">{{#if cta_text}}{{cta_text}}{{else}}{{#if cta_slide}}{{cta_slide.body}}{{/if}}{{/if}}</span></div>
        {{#if cta_handle}}<div class="handle">{{cta_handle}}</div>{{else}}{{#if cta_slide.handle}}<div class="handle">{{cta_slide.handle}}</div>{{/if}}{{/if}}
      </div>
      <div class="body">{{#if cta_slide.note}}{{cta_slide.note}}{{else}}Visual first. Text second. Leave room to breathe.{{/if}}</div>
    </div>
  </div>
</body>
</html>
