<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <title>Carousel — Voice Crew</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --safe: 80px;
      --ink: #0f0f1a;
      --paper-mint: #c8f2d4;
      --paper-pink: #ffd4e1;
      --paper-lilac: #e2d5fb;
      --paper-peach: #ffd6bf;
      --paper-sky: #cfe9ff;
      --skin-a: #f2c6a0;
      --skin-b: #c78b6a;
      --skin-c: #8e5a42;
      --skin-d: #623f2b;
      --hair-a: #1a1a1a;
      --hair-b: #e7b55c;
      --hair-c: #b94b3c;
      --hair-d: #9ec6ff;
      --tee-a: #ff5b8a;
      --tee-b: #2a3cff;
      --tee-c: #ff8a3d;
      --tee-d: #6a3dff;
      --accent: #2a3cff;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Outfit', sans-serif; background: #0f0f1a; color: var(--ink); }
    .slide { width: 1080px; height: 1350px; overflow: hidden; flex-shrink: 0; position: relative; }
    .slide-inner {
      width: 100%; height: 100%;
      position: relative;
      padding: var(--safe) var(--safe) 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: center;
      text-align: center;
      background: var(--paper-mint);
    }
    .slide:nth-of-type(5n+2) .slide-inner { background: var(--paper-pink); }
    .slide:nth-of-type(5n+3) .slide-inner { background: var(--paper-lilac); }
    .slide:nth-of-type(5n+4) .slide-inner { background: var(--paper-peach); }
    .slide:nth-of-type(5n+5) .slide-inner { background: var(--paper-sky); }

    .tag {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 34px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink);
      opacity: 0.7;
      margin-top: 12px;
    }
    .headline {
      font-family: 'Archivo Black', sans-serif;
      font-size: clamp(110px, 11.5vw, 148px);
      line-height: 1.0;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-top: 28px;
      max-width: 920px;
      z-index: 3;
      position: relative;
    }
    .headline .hash { color: var(--accent); }
    .subheadline {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: clamp(48px, 4.8vw, 60px);
      color: var(--ink);
      margin-top: 20px;
      max-width: 820px;
      z-index: 3;
      position: relative;
    }
    .body-copy {
      font-family: 'Outfit', sans-serif;
      font-weight: 500;
      font-size: clamp(46px, 4.6vw, 56px);
      line-height: 1.35;
      color: var(--ink);
      margin-top: 28px;
      max-width: 820px;
      z-index: 3;
      position: relative;
    }
    .cta-handle {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 46px;
      color: var(--accent);
      margin-top: 24px;
      z-index: 3;
      position: relative;
    }

    .wave {
      position: absolute;
      left: 0; right: 0;
      bottom: 360px;
      height: 120px;
      z-index: 1;
      opacity: 0.6;
    }

    .crew {
      position: absolute;
      left: 0; right: 0;
      bottom: 0;
      width: 100%;
      height: 520px;
      z-index: 2;
      display: block;
    }
  </style>
</head>
<body>
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <!-- A 4-woman crew silhouette bar; scaled to full slide width -->
      <symbol id="crew" viewBox="0 0 1080 520" preserveAspectRatio="xMidYMax slice">
        <!-- Woman 1 (left): bun hair, tank top, tattoos -->
        <g transform="translate(60,90)">
          <circle cx="110" cy="120" r="72" fill="var(--skin-a)" stroke="#0f0f1a" stroke-width="5"/>
          <circle cx="80" cy="60" r="28" fill="var(--hair-a)"/>
          <circle cx="140" cy="60" r="28" fill="var(--hair-a)"/>
          <path d="M50 120 Q50 60 110 60 Q170 60 170 120 L160 110 Q140 95 110 95 Q80 95 60 110 Z" fill="var(--hair-a)"/>
          <circle cx="95" cy="125" r="4" fill="#0f0f1a"/>
          <circle cx="125" cy="125" r="4" fill="#0f0f1a"/>
          <path d="M100 148 Q110 156 120 148" stroke="#0f0f1a" stroke-width="4" fill="none" stroke-linecap="round"/>
          <path d="M40 220 Q110 200 180 220 L200 430 L20 430 Z" fill="#ffffff" stroke="#0f0f1a" stroke-width="5"/>
          <path d="M90 280 L120 280 M100 300 L130 300" stroke="#ff5b8a" stroke-width="5" stroke-linecap="round"/>
          <text x="110" y="350" text-anchor="middle" font-family="Archivo Black" font-size="60" fill="#ff5b8a">✦</text>
        </g>

        <!-- Woman 2: blonde hair, holding megaphone (features center of composition) -->
        <g transform="translate(280,50)">
          <circle cx="130" cy="140" r="80" fill="var(--skin-b)" stroke="#0f0f1a" stroke-width="5"/>
          <path d="M55 150 Q55 60 130 60 Q205 60 205 150 L205 180 Q180 120 130 120 Q80 120 55 180 Z" fill="var(--hair-b)"/>
          <circle cx="110" cy="150" r="4" fill="#0f0f1a"/>
          <circle cx="150" cy="150" r="4" fill="#0f0f1a"/>
          <path d="M115 175 Q130 183 145 175" stroke="#0f0f1a" stroke-width="4" fill="none" stroke-linecap="round"/>
          <!-- body -->
          <path d="M50 240 Q130 220 210 240 L225 470 L35 470 Z" fill="#6a2a34" stroke="#0f0f1a" stroke-width="5"/>
          <!-- megaphone (held up) -->
          <g transform="translate(160,120) rotate(-12)">
            <path d="M0 40 L0 100 L60 120 L150 150 L170 0 L80 30 L60 30 Z" fill="#2f7b5a" stroke="#0f0f1a" stroke-width="5" stroke-linejoin="round"/>
            <rect x="-20" y="50" width="22" height="42" fill="#8fd2ad" stroke="#0f0f1a" stroke-width="5"/>
            <path d="M175 60 L210 40" stroke="#ffc63d" stroke-width="8" stroke-linecap="round"/>
            <path d="M180 90 L215 90" stroke="#ff6b2c" stroke-width="8" stroke-linecap="round"/>
            <path d="M175 120 L210 140" stroke="#ffc63d" stroke-width="8" stroke-linecap="round"/>
          </g>
        </g>

        <!-- Woman 3: afro hair, raised fist, orange top -->
        <g transform="translate(580,70)">
          <circle cx="130" cy="140" r="78" fill="var(--skin-c)" stroke="#0f0f1a" stroke-width="5"/>
          <ellipse cx="130" cy="85" rx="100" ry="60" fill="var(--hair-a)"/>
          <circle cx="130" cy="85" r="78" fill="var(--hair-a)"/>
          <circle cx="115" cy="145" r="4" fill="#ffffff"/>
          <circle cx="150" cy="145" r="4" fill="#ffffff"/>
          <path d="M115 170 Q132 180 150 170" stroke="#ffffff" stroke-width="4" fill="none" stroke-linecap="round"/>
          <circle cx="60" cy="170" r="12" fill="#ffc63d"/>
          <!-- body -->
          <path d="M45 240 Q130 222 215 240 L230 470 L30 470 Z" fill="var(--tee-c)" stroke="#0f0f1a" stroke-width="5"/>
          <!-- raised fist arm (behind head) -->
          <path d="M190 130 Q240 60 220 0" stroke="var(--skin-c)" stroke-width="36" fill="none" stroke-linecap="round"/>
          <circle cx="218" cy="-8" r="34" fill="var(--skin-c)" stroke="#0f0f1a" stroke-width="5"/>
          <rect x="203" y="-20" width="8" height="10" fill="#0f0f1a"/>
          <rect x="216" y="-20" width="8" height="10" fill="#0f0f1a"/>
          <rect x="229" y="-20" width="8" height="10" fill="#0f0f1a"/>
          <!-- purple ribbon -->
          <path d="M208 24 L238 24 L222 48 Z" fill="#6a3dff"/>
        </g>

        <!-- Woman 4: cap with flower, purple tank -->
        <g transform="translate(860,90)">
          <circle cx="110" cy="130" r="72" fill="var(--skin-b)" stroke="#0f0f1a" stroke-width="5"/>
          <path d="M40 130 Q40 70 110 70 Q180 70 180 130 L170 120 Q140 100 110 100 Q80 100 50 120 Z" fill="var(--hair-b)"/>
          <!-- cap -->
          <path d="M30 90 Q110 30 190 90 Q190 100 110 100 Q30 100 30 90 Z" fill="#0f0f1a"/>
          <path d="M30 92 Q40 102 60 98" stroke="#0f0f1a" stroke-width="5" fill="none"/>
          <!-- flower -->
          <g transform="translate(55,78)">
            <circle cx="0" cy="0" r="8" fill="#ffffff"/>
            <circle cx="-10" cy="-4" r="8" fill="#ffffff"/>
            <circle cx="10" cy="-4" r="8" fill="#ffffff"/>
            <circle cx="-5" cy="-12" r="8" fill="#ffffff"/>
            <circle cx="5" cy="-12" r="8" fill="#ffffff"/>
            <circle cx="0" cy="-4" r="5" fill="#ffc63d"/>
          </g>
          <circle cx="95" cy="135" r="4" fill="#0f0f1a"/>
          <circle cx="125" cy="135" r="4" fill="#0f0f1a"/>
          <path d="M100 160 Q110 168 120 160" stroke="#0f0f1a" stroke-width="4" fill="none" stroke-linecap="round"/>
          <path d="M40 220 Q110 200 180 220 L200 430 L20 430 Z" fill="var(--tee-d)" stroke="#0f0f1a" stroke-width="5"/>
        </g>
      </symbol>

      <symbol id="wave" viewBox="0 0 1080 120" preserveAspectRatio="none">
        <path d="M0 60 Q135 10 270 60 T540 60 T810 60 T1080 60 L1080 120 L0 120 Z" fill="rgba(255,255,255,0.6)"/>
      </symbol>
    </defs>
  </svg>

  <div class="slide cover">
    <div class="slide-inner">
      {{#if cover_slide.body}}<div class="tag">{{cover_slide.body}}</div>{{/if}}
      <div class="headline"><span class="hash">#</span>{{#if cover}}{{cover}}{{else}}{{cover_slide.headline}}{{/if}}</div>
      <svg class="wave" viewBox="0 0 1080 120" preserveAspectRatio="none"><use href="#wave"/></svg>
      <svg class="crew"><use href="#crew"/></svg>
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <div class="tag">Raise your voice</div>
      <div class="headline">{{headline}}</div>
      {{#if body}}<p class="body-copy">{{body}}</p>{{/if}}
      <svg class="wave" viewBox="0 0 1080 120" preserveAspectRatio="none"><use href="#wave"/></svg>
      <svg class="crew"><use href="#crew"/></svg>
    </div>
  </div>
  {{/each}}

  <div class="slide">
    <div class="slide-inner">
      <div class="tag">Join the movement</div>
      <div class="headline">{{#if cta_text}}{{cta_text}}{{else}}{{cta_slide.body}}{{/if}}</div>
      {{#if cta_handle}}<div class="cta-handle">{{cta_handle}}</div>{{else}}{{#if cta_slide.handle}}<div class="cta-handle">{{cta_slide.handle}}</div>{{/if}}{{/if}}
      <svg class="wave" viewBox="0 0 1080 120" preserveAspectRatio="none"><use href="#wave"/></svg>
      <svg class="crew"><use href="#crew"/></svg>
    </div>
  </div>
</body>
</html>
