<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <title>Carousel — Highlight Boxes</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Outfit:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --safe: 80px;
      --ink: #0f0f14;
      --paper-peach: #ffd6bf;
      --paper-mint: #d4f4dd;
      --paper-pink: #ffb8c6;
      --paper-lilac: #d9ccf7;
      --paper-cream: #fff4d8;
      --box-white: #ffffff;
      --box-black: #0f0f14;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Outfit', sans-serif; background: #0f0f14; color: var(--ink); }
    .slide { width: 1080px; height: 1350px; overflow: hidden; flex-shrink: 0; position: relative; }
    .slide-inner {
      width: 100%; height: 100%;
      position: relative;
      padding: var(--safe);
      display: flex;
      background: var(--paper-peach);
    }
    .slide:nth-of-type(5n+2) .slide-inner { background: var(--paper-pink); --box-white: var(--box-black); --ink: #ffffff; }
    .slide:nth-of-type(5n+3) .slide-inner { background: var(--paper-mint); }
    .slide:nth-of-type(5n+4) .slide-inner { background: var(--paper-lilac); }
    .slide:nth-of-type(5n+5) .slide-inner { background: var(--paper-cream); }

    /* Reset text color inside boxes regardless of palette inversion */
    .slide-inner { --box-text: #0f0f14; }
    .slide:nth-of-type(5n+2) .slide-inner { --box-text: #ffffff; }

    .scene {
      position: absolute;
      left: 0; bottom: 0;
      width: 60%;
      height: 100%;
      z-index: 1;
    }

    .text-col {
      position: relative;
      margin-left: auto;
      width: 46%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-end;
      gap: 22px;
      z-index: 3;
      text-align: right;
    }

    .box {
      display: inline-block;
      padding: 22px 34px;
      font-family: 'Archivo Black', sans-serif;
      font-size: clamp(82px, 8.4vw, 104px);
      line-height: 1.02;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      color: var(--box-text);
      background: var(--box-white);
      max-width: 100%;
      word-break: break-word;
    }

    .tag {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 32px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink);
      background: transparent;
      margin-bottom: 8px;
      padding: 0;
    }

    .body-copy {
      font-family: 'Outfit', sans-serif;
      font-weight: 500;
      font-size: 42px;
      line-height: 1.35;
      color: var(--ink);
      margin-top: 12px;
      max-width: 440px;
      text-align: right;
    }

    .cta-handle {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 42px;
      color: var(--ink);
      margin-top: 12px;
    }

    .ground {
      position: absolute;
      left: 0; bottom: 0;
      width: 100%;
      height: 240px;
      background: radial-gradient(ellipse at 30% 110%, rgba(15,15,26,0.10) 0%, rgba(15,15,26,0) 70%);
      z-index: 0;
    }
  </style>
</head>
<body>
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <!-- Scene: seated woman with guitar / plant / nature backdrop (composite scene) -->
      <symbol id="scene" viewBox="0 0 640 1200" preserveAspectRatio="xMinYMax meet">
        <!-- soft hills backdrop -->
        <ellipse cx="180" cy="900" rx="380" ry="190" fill="rgba(122,155,142,0.35)"/>
        <ellipse cx="500" cy="1000" rx="300" ry="140" fill="rgba(122,155,142,0.25)"/>
        <!-- couch -->
        <rect x="60" y="820" width="540" height="260" rx="32" fill="#ffe0d0" stroke="#0f0f14" stroke-width="6"/>
        <rect x="60" y="820" width="540" height="70" rx="32" fill="#ffb8a0" stroke="#0f0f14" stroke-width="6"/>
        <!-- cushion -->
        <circle cx="520" cy="860" r="48" fill="#ff8aa0" stroke="#0f0f14" stroke-width="5"/>

        <!-- Woman sitting cross-legged -->
        <g transform="translate(110,540)">
          <!-- head -->
          <circle cx="150" cy="140" r="80" fill="#8e5a42" stroke="#0f0f14" stroke-width="5"/>
          <!-- hair: two space buns -->
          <circle cx="90" cy="68" r="36" fill="#0f0f14"/>
          <circle cx="210" cy="68" r="36" fill="#0f0f14"/>
          <path d="M70 150 Q70 70 150 70 Q230 70 230 150 L220 140 Q190 110 150 110 Q110 110 80 140 Z" fill="#0f0f14"/>
          <!-- face -->
          <circle cx="128" cy="148" r="5" fill="#0f0f14"/>
          <circle cx="172" cy="148" r="5" fill="#0f0f14"/>
          <path d="M132 180 Q150 192 168 180" stroke="#0f0f14" stroke-width="4" fill="none" stroke-linecap="round"/>
          <!-- crop top -->
          <path d="M78 240 Q150 220 222 240 L220 320 L80 320 Z" fill="#ffb0c4" stroke="#0f0f14" stroke-width="5"/>
          <!-- skin midriff -->
          <path d="M90 320 Q150 330 210 320 L210 360 L90 360 Z" fill="#8e5a42"/>
          <!-- pants cross-legged -->
          <path d="M70 360 Q150 350 230 360 L270 510 L30 510 Z" fill="#3a52c4" stroke="#0f0f14" stroke-width="5"/>
          <rect x="20" y="490" width="120" height="40" rx="18" fill="#ffffff" stroke="#0f0f14" stroke-width="5"/>
          <rect x="170" y="490" width="120" height="40" rx="18" fill="#ffffff" stroke="#0f0f14" stroke-width="5"/>
          <circle cx="80" cy="510" r="14" fill="#ff5b8a"/>
          <circle cx="230" cy="510" r="14" fill="#ff5b8a"/>
        </g>

        <!-- guitar leaning -->
        <g transform="translate(380,620)">
          <rect x="30" y="0" width="18" height="280" fill="#ffd4de" stroke="#0f0f14" stroke-width="5"/>
          <ellipse cx="40" cy="320" rx="80" ry="110" fill="#ffd4de" stroke="#0f0f14" stroke-width="5"/>
          <circle cx="40" cy="300" r="24" fill="#0f0f14"/>
          <line x1="36" y1="20" x2="36" y2="280" stroke="#0f0f14" stroke-width="2"/>
          <line x1="42" y1="20" x2="42" y2="280" stroke="#0f0f14" stroke-width="2"/>
        </g>

        <!-- pink wall frame -->
        <rect x="40" y="120" width="220" height="220" rx="8" fill="#ffffff" stroke="#0f0f14" stroke-width="5"/>
        <path d="M70 260 Q110 200 180 240 Q210 220 240 260 L240 320 L70 320 Z" fill="#ffd4de"/>
        <circle cx="200" cy="210" r="18" fill="#ff9fbe"/>

        <!-- potted plant -->
        <g transform="translate(520,700)">
          <rect x="0" y="60" width="70" height="90" fill="#e0e0e0" stroke="#0f0f14" stroke-width="5"/>
          <path d="M10 60 Q-10 -20 50 20 Q80 -30 70 40 Q120 10 80 80 Z" fill="#6a9b6d" stroke="#0f0f14" stroke-width="5"/>
        </g>
      </symbol>

      <!-- Scene B: desk / workspace (for IT'S ALREADY YOURS variant) -->
      <symbol id="scene-desk" viewBox="0 0 640 1200" preserveAspectRatio="xMinYMax meet">
        <rect x="80" y="100" width="500" height="360" rx="12" fill="#ffb8c6" stroke="#0f0f14" stroke-width="5"/>
        <rect x="110" y="130" width="440" height="300" fill="#ffffff" stroke="#0f0f14" stroke-width="5"/>
        <!-- desk -->
        <rect x="60" y="760" width="540" height="30" fill="#ffb8c6" stroke="#0f0f14" stroke-width="5"/>
        <rect x="100" y="790" width="30" height="280" fill="#ffb8c6" stroke="#0f0f14" stroke-width="5"/>
        <rect x="530" y="790" width="30" height="280" fill="#ffb8c6" stroke="#0f0f14" stroke-width="5"/>
        <!-- chair -->
        <ellipse cx="330" cy="800" rx="130" ry="28" fill="#0f0f14"/>
        <rect x="200" y="540" width="260" height="240" rx="20" fill="#0f0f14"/>
        <rect x="315" y="780" width="30" height="180" fill="#0f0f14"/>
        <!-- monitor -->
        <rect x="240" y="600" width="180" height="130" rx="10" fill="#ffffff" stroke="#0f0f14" stroke-width="5"/>
        <rect x="322" y="730" width="16" height="26" fill="#0f0f14"/>
        <!-- plants on side -->
        <g transform="translate(80,620)">
          <path d="M20 140 Q-20 40 40 60 Q20 10 60 60 Q100 30 70 100 Z" fill="#6a9b6d" stroke="#0f0f14" stroke-width="5"/>
          <rect x="10" y="140" width="70" height="50" fill="#ffffff" stroke="#0f0f14" stroke-width="5"/>
        </g>
        <g transform="translate(500,640)">
          <path d="M20 120 Q-10 30 40 50 Q80 10 70 80 Z" fill="#6a9b6d" stroke="#0f0f14" stroke-width="5"/>
          <rect x="10" y="120" width="60" height="40" fill="#ffffff" stroke="#0f0f14" stroke-width="5"/>
        </g>
        <!-- mug -->
        <rect x="440" y="720" width="46" height="50" fill="#0f0f14"/>
        <path d="M486 730 Q510 740 486 760" stroke="#0f0f14" stroke-width="6" fill="none"/>
      </symbol>
    </defs>
  </svg>

  <div class="slide cover">
    <div class="slide-inner">
      <svg class="scene"><use href="#scene"/></svg>
      <div class="ground"></div>
      <div class="text-col">
        {{#if cover_slide.body}}<div class="tag">{{cover_slide.body}}</div>{{/if}}
        <span class="box">{{#if cover}}{{cover}}{{else}}{{cover_slide.headline}}{{/if}}</span>
      </div>
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <svg class="scene"><use href="#scene-desk"/></svg>
      <div class="ground"></div>
      <div class="text-col">
        <span class="box">{{headline}}</span>
        {{#if body}}<p class="body-copy">{{body}}</p>{{/if}}
      </div>
    </div>
  </div>
  {{/each}}

  <div class="slide">
    <div class="slide-inner">
      <svg class="scene"><use href="#scene"/></svg>
      <div class="ground"></div>
      <div class="text-col">
        <span class="box">{{#if cta_text}}{{cta_text}}{{else}}{{cta_slide.body}}{{/if}}</span>
        {{#if cta_handle}}<div class="cta-handle">{{cta_handle}}</div>{{else}}{{#if cta_slide.handle}}<div class="cta-handle">{{cta_slide.handle}}</div>{{/if}}{{/if}}
      </div>
    </div>
  </div>
</body>
</html>
