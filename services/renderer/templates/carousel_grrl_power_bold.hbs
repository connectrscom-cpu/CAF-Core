<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <title>Carousel — Grrl Power Bold</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --safe: 90px;
      --ink: #0f0f1a;
      --paper: #ffffff;
      --blue: #2a3cff;
      --cyan: #25d0eb;
      --violet: #7a52ff;
      --yellow: #ffe259;
      --rose: #ff5b8a;
      --peach: #ffb48a;
      --skin-1: #f2c6a0;
      --skin-2: #d89a74;
      --skin-3: #a26b4f;
      --skin-4: #6e4630;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Outfit', sans-serif; background: #0f0f1a; color: var(--ink); }
    .slide { width: 1080px; height: 1350px; overflow: hidden; flex-shrink: 0; position: relative; }
    .slide-inner {
      width: 100%; height: 100%;
      position: relative;
      padding: var(--safe);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      text-align: left;
    }
    .slide:nth-of-type(6n+1) .slide-inner { background: var(--blue); color: var(--paper); }
    .slide:nth-of-type(6n+2) .slide-inner { background: var(--cyan); color: var(--paper); }
    .slide:nth-of-type(6n+3) .slide-inner { background: var(--violet); color: var(--paper); }
    .slide:nth-of-type(6n+4) .slide-inner { background: var(--yellow); color: var(--ink); }
    .slide:nth-of-type(6n+5) .slide-inner { background: var(--rose); color: var(--paper); }
    .slide:nth-of-type(6n+6) .slide-inner { background: var(--peach); color: var(--ink); }

    .tag {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 34px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      opacity: 0.85;
      margin-bottom: 18px;
      z-index: 3;
      position: relative;
    }
    .headline {
      font-family: 'Archivo Black', sans-serif;
      font-size: clamp(150px, 15vw, 190px);
      line-height: 0.92;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      max-width: 780px;
      z-index: 3;
      position: relative;
      word-break: break-word;
    }
    .subheadline {
      font-family: 'Archivo Black', sans-serif;
      font-size: clamp(88px, 9vw, 120px);
      line-height: 0.98;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      max-width: 780px;
      z-index: 3;
      position: relative;
    }
    .body-copy {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: clamp(54px, 5.4vw, 66px);
      line-height: 1.2;
      margin-top: 36px;
      max-width: 760px;
      z-index: 3;
      position: relative;
    }
    .cta-wrap { margin-top: auto; z-index: 3; position: relative; }
    .cta-headline {
      font-family: 'Archivo Black', sans-serif;
      font-size: clamp(110px, 11vw, 150px);
      line-height: 0.95;
      text-transform: uppercase;
      letter-spacing: -0.02em;
      max-width: 780px;
    }
    .cta-handle {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 48px;
      margin-top: 28px;
    }

    .character { position: absolute; right: 0; bottom: 0; width: 620px; height: 820px; z-index: 2; }
    .deco-room { position: absolute; left: 0; bottom: 0; width: 100%; height: 45%; z-index: 1; opacity: 0.95; pointer-events: none; }
    .deco-shapes { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
  </style>
</head>
<body>
  <!-- Reusable SVGs: protest woman silhouette with raised fist -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <symbol id="activist" viewBox="0 0 600 820">
        <!-- back sign -->
        <rect x="90" y="70" width="220" height="180" fill="#ffffff" stroke="#0f0f1a" stroke-width="8" rx="10"/>
        <text x="200" y="185" text-anchor="middle" font-family="Archivo Black, sans-serif" font-size="120" fill="#0f0f1a">♀</text>
        <!-- arm holding sign -->
        <path d="M240 230 Q230 320 250 400" stroke="var(--skin-2)" stroke-width="48" fill="none" stroke-linecap="round"/>
        <!-- raised fist arm -->
        <path d="M430 300 Q500 200 470 110" stroke="var(--skin-2)" stroke-width="52" fill="none" stroke-linecap="round"/>
        <circle cx="465" cy="85" r="48" fill="var(--skin-2)" stroke="#0f0f1a" stroke-width="6"/>
        <rect x="448" y="70" width="12" height="12" fill="#0f0f1a"/>
        <rect x="467" y="70" width="12" height="12" fill="#0f0f1a"/>
        <rect x="486" y="70" width="10" height="12" fill="#0f0f1a"/>
        <!-- head -->
        <circle cx="330" cy="330" r="90" fill="var(--skin-2)" stroke="#0f0f1a" stroke-width="6"/>
        <!-- hair -->
        <path d="M240 330 Q240 210 330 210 Q430 210 430 330 L420 300 Q400 260 330 260 Q260 260 250 310 Z" fill="#0f0f1a"/>
        <!-- simple face -->
        <circle cx="305" cy="335" r="6" fill="#0f0f1a"/>
        <circle cx="355" cy="335" r="6" fill="#0f0f1a"/>
        <path d="M310 370 Q330 385 350 370" stroke="#0f0f1a" stroke-width="5" fill="none" stroke-linecap="round"/>
        <!-- body / shirt -->
        <path d="M220 450 Q330 420 440 450 L460 820 L200 820 Z" fill="#ff5b8a" stroke="#0f0f1a" stroke-width="6"/>
        <!-- star accent on shirt -->
        <text x="330" y="620" text-anchor="middle" font-family="Outfit, sans-serif" font-weight="700" font-size="120" fill="#ffffff">★</text>
        <!-- legs -->
        <rect x="255" y="740" width="70" height="120" fill="#2a3cff" stroke="#0f0f1a" stroke-width="6"/>
        <rect x="335" y="740" width="70" height="120" fill="#2a3cff" stroke="#0f0f1a" stroke-width="6"/>
      </symbol>

      <symbol id="room" viewBox="0 0 1080 600">
        <!-- floor -->
        <rect x="0" y="380" width="1080" height="220" fill="rgba(15,15,26,0.08)"/>
        <!-- rug -->
        <ellipse cx="540" cy="530" rx="420" ry="44" fill="rgba(255,255,255,0.35)"/>
        <!-- door -->
        <path d="M70 200 Q70 140 130 140 Q190 140 190 200 L190 440 L70 440 Z" fill="rgba(255,255,255,0.85)" stroke="#0f0f1a" stroke-width="6"/>
        <circle cx="170" cy="320" r="7" fill="#0f0f1a"/>
        <!-- stair block -->
        <polygon points="820,440 1050,440 1050,380 970,380 970,320 890,320 890,260 820,260" fill="rgba(255,255,255,0.7)" stroke="#0f0f1a" stroke-width="6"/>
        <!-- window -->
        <rect x="700" y="140" width="130" height="130" fill="rgba(255,255,255,0.85)" stroke="#0f0f1a" stroke-width="6"/>
        <line x1="765" y1="140" x2="765" y2="270" stroke="#0f0f1a" stroke-width="6"/>
        <line x1="700" y1="205" x2="830" y2="205" stroke="#0f0f1a" stroke-width="6"/>
        <circle cx="860" cy="170" r="24" fill="#ffb48a" stroke="#0f0f1a" stroke-width="6"/>
      </symbol>

      <symbol id="shapes" viewBox="0 0 1080 1350">
        <circle cx="120" cy="1100" r="38" fill="#ffffff" opacity="0.25"/>
        <rect x="900" y="140" width="50" height="50" fill="#ffffff" opacity="0.25"/>
        <circle cx="960" cy="1180" r="22" fill="#ffffff" opacity="0.35"/>
      </symbol>
    </defs>
  </svg>

  <div class="slide cover">
    <div class="slide-inner">
      <svg class="deco-shapes"><use href="#shapes"/></svg>
      <svg class="deco-room" viewBox="0 0 1080 600" preserveAspectRatio="xMidYMax slice"><use href="#room"/></svg>
      {{#if cover_slide.body}}<div class="tag">{{cover_slide.body}}</div>{{/if}}
      <div class="headline">{{#if cover}}{{cover}}{{else}}{{cover_slide.headline}}{{/if}}</div>
      <svg class="character"><use href="#activist"/></svg>
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <svg class="deco-shapes"><use href="#shapes"/></svg>
      <svg class="deco-room" viewBox="0 0 1080 600" preserveAspectRatio="xMidYMax slice"><use href="#room"/></svg>
      <div class="tag">Small tag goes here</div>
      <div class="subheadline">{{headline}}</div>
      {{#if body}}<p class="body-copy">{{body}}</p>{{/if}}
      <svg class="character"><use href="#activist"/></svg>
    </div>
  </div>
  {{/each}}

  <div class="slide">
    <div class="slide-inner">
      <svg class="deco-shapes"><use href="#shapes"/></svg>
      <svg class="deco-room" viewBox="0 0 1080 600" preserveAspectRatio="xMidYMax slice"><use href="#room"/></svg>
      <div class="cta-wrap">
        <div class="cta-headline">{{#if cta_text}}{{cta_text}}{{else}}{{cta_slide.body}}{{/if}}</div>
        {{#if cta_handle}}<div class="cta-handle">{{cta_handle}}</div>{{else}}{{#if cta_slide.handle}}<div class="cta-handle">{{cta_slide.handle}}</div>{{/if}}{{/if}}
      </div>
      <svg class="character"><use href="#activist"/></svg>
    </div>
  </div>
</body>
</html>
