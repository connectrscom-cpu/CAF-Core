<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

  <style>
    :root{
      --caf-carousel-headline-size: 72px;
      --caf-carousel-body-size: 38px;
      --caf-carousel-kicker-size: 18px;
      --caf-carousel-cta-size: 72px;

      --pad-x: 78px;
      --pad-y: 88px;

      --paper: #fffef9;
      --ink: #1c1c1e;
      --body: #3a3a3c;
      --text-shadow-headline: 0 1px 12px rgba(255,254,249,0.85);
      --text-shadow-body: 0 1px 10px rgba(255,254,249,0.8);
    }

    *{
      box-sizing:border-box;
      margin:0;
      padding:0;
    }

    body{
      background:var(--paper);
    }

    .slide{
      width:1080px;
      height:1350px;
      overflow:hidden;
      flex-shrink:0;
      position:relative;
      background:var(--paper);
      font-family:Inter,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
      color:var(--ink);
      -webkit-font-smoothing:antialiased;
    }

    .slide-bg{
      position:absolute;
      inset:0;
      z-index:0;
      background-color:var(--paper);
      background-size:cover;
      background-position:center;
      background-repeat:no-repeat;
    }

    .page{
      position:relative;
      z-index:1;
      width:100%;
      height:100%;
      max-height:100%;
      padding: var(--pad-y) var(--pad-x);
      display:flex;
      flex-direction:column;
      align-items: var(--caf-page-align, stretch);
      justify-content: var(--caf-page-justify, flex-start);
      text-align: var(--caf-text-align, left);
      overflow-y:auto;
      overflow-x:hidden;
      -webkit-overflow-scrolling:touch;
      box-sizing:border-box;
    }

    .mimic-text-stack{
      display:flex;
      flex-direction:column;
      width:100%;
      max-width:920px;
      box-sizing:border-box;
    }

  .page.mimic-block-positioned{
      display:block;
      padding:0;
    }

    .page.mimic-block-positioned .mimic-text-stack{
      position:absolute;
      z-index:2;
      left:calc(var(--pad-x) + var(--caf-text-x, 0.08) * (100% - 2 * var(--pad-x)));
      top:calc(var(--pad-y) + var(--caf-text-y, 0.12) * (100% - 2 * var(--pad-y)));
      width:calc(var(--caf-text-w, 0.84) * (100% - 2 * var(--pad-x)));
      max-width:none;
      margin:0;
    }

    .page .headline,
    .page .body,
    .page .sub,
    .page .handle,
    .page .cta-handle,
    .mimic-text-stack .headline,
    .mimic-text-stack .body,
    .mimic-text-stack .sub,
    .mimic-text-stack .handle,
    .mimic-text-stack .cta-handle{
      width:100%;
      max-width:920px;
    }

    .headline{
      font-weight:700;
      font-size:68px;
      line-height:1.12;
      letter-spacing:-0.028em;
      color:var(--ink);
      text-align:inherit;
      overflow-wrap:anywhere;
      word-break:break-word;
      text-shadow: var(--text-shadow-headline, 0 1px 12px rgba(255,254,249,0.85));
    }

    .cover .headline{
      line-height:1.06;
    }

    .body,
    .sub,
    .handle,
    .cta-handle{
      margin-top:28px;
      font-weight:400;
      font-size:38px;
      line-height:1.45;
      color:var(--body);
      text-align:inherit;
      white-space:pre-wrap;
      overflow-wrap:anywhere;
      word-break:break-word;
      min-width:0;
      max-width:100%;
      text-shadow: var(--text-shadow-body, 0 1px 10px rgba(255,254,249,0.8));
    }

    .handle,
    .cta-handle{
      margin-top:12px;
      font-weight:700;
    }

    .cta .headline{
      line-height:1.08;
    }

    .kicker{
      font-size: var(--caf-carousel-kicker-size, 18px) !important;
    }

    .main-headline{
      font-size: var(--caf-carousel-headline-size, 72px) !important;
    }

    .main-body{
      font-size: var(--caf-carousel-body-size, 72px) !important;
    }

    .cta-text{
      font-size: var(--caf-carousel-cta-size, 72px) !important;
    }

    /* Document AI per-block text overlay (reference bbox + typography, LLM copy) */
    .page.mimic-docai-layers{
      display:block;
      padding:0;
    }

    .mimic-docai-layer{
      position:absolute;
      z-index:2;
      margin:0;
      padding:0;
      box-sizing:border-box;
      line-height:1.12;
      letter-spacing:-0.02em;
      overflow-wrap:anywhere;
      word-break:break-word;
      white-space:pre-wrap;
      text-shadow: var(--text-shadow-headline, 0 1px 12px rgba(255,254,249,0.85));
    }

    .mimic-docai-layer--body,
    .mimic-docai-layer--subtitle,
    .mimic-docai-layer--caption,
    .mimic-docai-layer--paragraph,
    .mimic-docai-layer--sub{
      line-height:1.45;
      text-shadow: var(--text-shadow-body, 0 1px 10px rgba(255,254,249,0.8));
    }
  </style>
</head>

<body>
  <!-- Cover -->
  <div class="slide cover">
    {{#if background_image_url}}
    <div class="slide-bg" style="background-image:url('{{{background_image_url}}}');"></div>
    {{/if}}
    <div class="page{{#if mimic_use_docai_layers}} mimic-docai-layers{{else}}{{#if mimic_use_block_positioning}} mimic-block-positioned{{/if}}{{/if}}">
      {{#if mimic_render_text_layers}}
        {{#each mimic_render_text_layers}}
        <div class="mimic-docai-layer mimic-docai-layer--{{role}}" style="{{css_style}}">{{joinEmojiOrphans text}}</div>
        {{/each}}
      {{else}}
      <div class="mimic-text-stack">
      <div class="headline main-headline">
        {{#if cover}}
          {{joinEmojiOrphans cover}}
        {{else}}
          {{#if cover_slide}}
            {{joinEmojiOrphans cover_slide.headline}}
          {{else}}
            {{joinEmojiOrphans intro_title}}
          {{/if}}
        {{/if}}
      </div>

      {{#if cover_subtitle}}
        <div class="body main-body">{{joinEmojiOrphans cover_subtitle}}</div>
      {{else}}
        {{#if cover_slide.body}}
          <div class="body main-body">{{joinEmojiOrphans cover_slide.body}}</div>
        {{/if}}
      {{/if}}
      </div>
      {{/if}}
    </div>
  </div>

  {{#each body_slides}}
  <div class="slide body-slide">
    {{#if ../background_image_url}}
    <div class="slide-bg" style="background-image:url('{{{../background_image_url}}}');"></div>
    {{/if}}
    <div class="page{{#if ../mimic_use_docai_layers}} mimic-docai-layers{{else}}{{#if ../mimic_use_block_positioning}} mimic-block-positioned{{/if}}{{/if}}">
      {{#if ../mimic_render_text_layers}}
        {{#each ../mimic_render_text_layers}}
        <div class="mimic-docai-layer mimic-docai-layer--{{role}}" style="{{css_style}}">{{joinEmojiOrphans text}}</div>
        {{/each}}
      {{else}}
      <div class="mimic-text-stack">
      <div class="headline main-headline">{{joinEmojiOrphans headline}}</div>
      <div class="body main-body">{{joinEmojiOrphans body}}</div>
      </div>
      {{/if}}
    </div>
  </div>
  {{/each}}

  <!-- CTA -->
  <div class="slide cta">
    {{#if background_image_url}}
    <div class="slide-bg" style="background-image:url('{{{background_image_url}}}');"></div>
    {{/if}}
    <div class="page{{#if mimic_use_docai_layers}} mimic-docai-layers{{else}}{{#if mimic_use_block_positioning}} mimic-block-positioned{{/if}}{{/if}}">
      {{#if mimic_render_text_layers}}
        {{#each mimic_render_text_layers}}
        <div class="mimic-docai-layer mimic-docai-layer--{{role}}" style="{{css_style}}">{{joinEmojiOrphans text}}</div>
        {{/each}}
      {{else}}
      <div class="mimic-text-stack">
      <div class="headline cta-text">
        {{#if cta_text}}
          {{joinEmojiOrphans cta_text}}
        {{else}}
          {{#if cta_slide}}
            {{joinEmojiOrphans cta_slide.body}}
          {{/if}}
        {{/if}}
      </div>

      {{#if cta_slide.sub}}
        <div class="sub main-body">{{joinEmojiOrphans cta_slide.sub}}</div>
      {{else}}
        {{#if cta_handle}}
          <div class="handle main-body">{{cta_handle}}</div>
        {{else}}
          {{#if cta_slide.handle}}
            <div class="handle main-body">{{cta_slide.handle}}</div>
          {{/if}}
        {{/if}}
      {{/if}}
      </div>
      {{/if}}
    </div>
  </div>
</body>
</html>
