<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --safe: 92px;
      --bg: #0a0a0e;
      --text: #f5f5f7;
      --muted: #b7b7c2;
      --accent: #9b5cff;
      --accent2: #ff5c8a;
      --border: rgba(255,255,255,0.08);
      --shadow: 0 28px 70px rgba(0,0,0,0.45);
      --radius: 40px;
    }
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:Inter,system-ui,Arial,sans-serif;background:var(--bg);color:var(--text);}
    .slide{
      width:1080px;height:1350px;overflow:hidden;flex-shrink:0;
      background: radial-gradient(circle at 12% 10%, rgba(155,92,255,0.18), transparent 40%),
                  radial-gradient(circle at 92% 92%, rgba(255,92,138,0.18), transparent 45%),
                  var(--bg);
    }
    .frame{
      position:relative;width:100%;height:100%;
      padding:var(--safe);
      display:flex;flex-direction:column;justify-content:flex-start;
      gap: 26px;
      border: 1px solid rgba(255,255,255,0.06);
    }
    /* Guardrail: never tilt text in this template */
    .headline, .body, .cta, .handle { transform: none !important; }
    .frame::before{
      content:"";position:absolute;inset:38px;border-radius:var(--radius);
      border:1px solid var(--border);
      box-shadow:var(--shadow);
      pointer-events:none;
    }
    .kicker{font-size:18px;letter-spacing:0.18em;text-transform:uppercase;opacity:0.9;color:var(--muted);}
    .kicker-line{
      width:140px;height:6px;border-radius:999px;margin:28px 0 34px;
      background:linear-gradient(90deg,var(--accent),var(--accent2));
      box-shadow:0 0 24px rgba(155,92,255,0.25);
    }
    h1,h2,h3{letter-spacing:-0.04em;}
    .headline{
      font-weight:800;
      font-size:clamp(44px, 8.5vw, 96px);
      line-height:1.02;
      max-width: 920px;
      text-align:left;
      overflow-wrap:anywhere;
      word-break:break-word;
      hyphens:auto;
    }
    .accent{color:var(--accent);}
    .accent2{color:var(--accent2);}
    .body{
      font-size:56px;line-height:1.32;color:var(--muted);
      max-width: 920px;
      text-align:left;
      overflow-wrap:anywhere;
      word-break:break-word;
      hyphens:auto;
    }
    .cta{
      font-weight:800;
      font-size:clamp(40px, 7.5vw, 86px);
      line-height:1.05;
      max-width:920px;
      text-align:left;
      overflow-wrap:anywhere;
      word-break:break-word;
      hyphens:auto;
    }
    .handle{
      margin-top:18px;
      font-weight:700;
      font-size:42px;
      letter-spacing:0.06em;
      color:rgba(245,245,247,0.85);
    }
    /* CTA: one primary text stack (no separate body block under the headline) */
    .cta--single{
      display:flex;
      flex-direction:column;
      align-items:flex-start;
      gap: 16px;
    }
    .cta--single .handle--inline{
      margin-top: 0;
    }
    .cta-follow{
      font-weight:700;
      font-size:40px;
      line-height:1.32;
      color:var(--muted);
      letter-spacing:0.01em;
    }
  </style>
</head>
<body>
  <!-- Cover -->
  <div class="slide">
    <div class="frame">
      <div>
        <div class="kicker">{{#if cover_slide.kicker}}{{cover_slide.kicker}}{{else}}Slide 01 / Hook{{/if}}</div>
        <div class="kicker-line"></div>
        <div class="headline">
          {{#if cover}}{{cover}}{{else}}{{#if cover_slide}}{{cover_slide.headline}}{{else}}{{intro_title}}{{/if}}{{/if}}
        </div>
      </div>
      <div class="body">
        {{#if cover_subtitle}}{{cover_subtitle}}{{else}}{{#if cover_slide}}{{cover_slide.body}}{{/if}}{{/if}}
      </div>
    </div>
  </div>

  <!-- Body -->
  {{#each body_slides}}
  <div class="slide">
    <div class="frame">
      <div>
        <div class="headline">
          {{headline}}
        </div>
      </div>
      <div class="body">{{body}}</div>
    </div>
  </div>
  {{/each}}

  <!-- CTA -->
  <div class="slide">
    <div class="frame">
      <div>
        <div class="kicker">{{#if cta_slide.kicker}}{{cta_slide.kicker}}{{else}}Final / CTA{{/if}}</div>
        <div class="kicker-line"></div>
        <div class="cta cta--single">
          <span class="accent2">{{#if cta_text}}{{cta_text}}{{else}}{{#if cta_slide}}{{cta_slide.body}}{{/if}}{{/if}}</span>
          {{#if cta_handle}}<span class="handle handle--inline">{{cta_handle}}</span>{{else}}{{#if cta_slide.handle}}<span class="handle handle--inline">{{cta_slide.handle}}</span>{{/if}}{{/if}}
          <span class="cta-follow">{{#if cta_slide.follow_line}}{{cta_slide.follow_line}}{{else}}Follow us for more.{{/if}}</span>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
