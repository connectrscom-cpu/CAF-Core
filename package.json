{
  "name": "caf-core",
  "version": "0.1.0",
  "private": true,
  "description": "CAF Core — decision engine, Postgres state, learning rules, suppression",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "node --watch --import tsx src/server.ts",
    "migrate": "node --import tsx src/cli/migrate.ts",
    "seed:demo": "node --import tsx src/cli/seed-demo.ts",
    "sync:sheets": "node --import tsx src/cli/sync-sheets.ts",
    "sync:supabase": "node --import tsx src/cli/sync-supabase.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "@supabase/supabase-js": "^2.49.1",
    "googleapis": "^144.0.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
